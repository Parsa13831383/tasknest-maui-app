<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Label">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
        <Setter Property="FontFamily"
                Value="OpenSansRegular"/>
    </Style>

    <Style x:Key="H1"
            TargetType="Label">
        <Setter Property="FontSize"
                Value="26"/>
        <Setter Property="FontAttributes"
                Value="Bold"/>
    </Style>

    <Style x:Key="Subtle"
            TargetType="Label">
        <Setter Property="Opacity"
                Value="0.75"/>
        <Setter Property="FontSize"
                Value="13"/>
    </Style>

    <Style x:Key="DashboardEyebrow"
           TargetType="Label">
        <Setter Property="FontFamily"
                Value="OpenSansSemibold"/>
        <Setter Property="FontSize"
                Value="12"/>
        <Setter Property="TextColor"
                Value="{StaticResource TextSecondary}"/>
        <Setter Property="CharacterSpacing"
                Value="1.2"/>
        <Setter Property="TextTransform"
                Value="Uppercase"/>
    </Style>

    <Style x:Key="DashboardTitle"
           TargetType="Label">
        <Setter Property="FontFamily"
                Value="OpenSansSemibold"/>
        <Setter Property="FontSize"
                Value="30"/>
        <Setter Property="TextColor"
                Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="DashboardSubtitle"
           TargetType="Label">
        <Setter Property="FontFamily"
                Value="OpenSansRegular"/>
        <Setter Property="FontSize"
                Value="15"/>
        <Setter Property="TextColor"
                Value="{StaticResource TextSecondary}"/>
        <Setter Property="Opacity"
                Value="0.78"/>
    </Style>

    <Style x:Key="DashboardSectionTitle"
           TargetType="Label">
        <Setter Property="FontFamily"
                Value="OpenSansSemibold"/>
        <Setter Property="FontSize"
                Value="19"/>
        <Setter Property="TextColor"
                Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="DashboardCardLabel"
           TargetType="Label">
        <Setter Property="FontFamily"
                Value="OpenSansSemibold"/>
        <Setter Property="TextColor"
                Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="DashboardCardValue"
           TargetType="Label">
        <Setter Property="FontFamily"
                Value="OpenSansSemibold"/>
        <Setter Property="FontSize"
                Value="24"/>
        <Setter Property="TextColor"
                Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="DashboardCardSubtext"
           TargetType="Label">
        <Setter Property="FontFamily"
                Value="OpenSansRegular"/>
        <Setter Property="FontSize"
                Value="13"/>
        <Setter Property="TextColor"
                Value="{StaticResource TextSecondary}"/>
        <Setter Property="Opacity"
                Value="0.78"/>
    </Style>

    <Style x:Key="DashboardPrimaryActionButton"
           TargetType="Button">
        <Setter Property="BackgroundColor"
                Value="{StaticResource Accent}"/>
        <Setter Property="TextColor"
                Value="White"/>
        <Setter Property="FontFamily"
                Value="OpenSansSemibold"/>
        <Setter Property="CornerRadius"
                Value="16"/>
        <Setter Property="HeightRequest"
                Value="52"/>
        <Setter Property="Padding"
                Value="18,14"/>
    </Style>

    <Style x:Key="DashboardSecondaryActionButton"
           TargetType="Button">
        <Setter Property="BackgroundColor"
                Value="{StaticResource SurfaceMuted}"/>
        <Setter Property="TextColor"
                Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily"
                Value="OpenSansSemibold"/>
        <Setter Property="CornerRadius"
                Value="16"/>
        <Setter Property="HeightRequest"
                Value="52"/>
        <Setter Property="Padding"
                Value="18,14"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="CornerRadius"
                Value="14"/>
        <Setter Property="HeightRequest"
                Value="48"/>
    </Style>

</ResourceDictionary>