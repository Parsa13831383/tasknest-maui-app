<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="TaskNest.Controls.TaskCard"
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Frame
        Padding="0"
        Margin="0,0,0,12"
        CornerRadius="16"
        BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
        BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
        HasShadow="False">

        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="6,*">

            <!-- Accent color strip -->
            <BoxView
                Grid.RowSpan="2"
                Grid.Column="0"
                Color="{Binding TaskColor}"
                WidthRequest="6"/>

            <!-- Main content area -->
            <VerticalStackLayout
                Grid.Row="0"
                Grid.Column="1"
                Padding="16,16,16,12"
                Spacing="10">

                <!-- Title row with color dot -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="{Binding Title}"
                            FontSize="17"
                            FontFamily="OpenSansSemibold"
                            TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"
                            LineBreakMode="TailTruncation"
                            MaxLines="2"/>
                        <Label
                            Text="{Binding Description}"
                            FontSize="13"
                            FontFamily="OpenSansRegular"
                            TextColor="{AppThemeBinding Light=#8E8E93, Dark=#98989D}"
                            LineBreakMode="TailTruncation"
                            MaxLines="2"/>
                    </VerticalStackLayout>

                    <Border
                        Grid.Column="1"
                        WidthRequest="14"
                        HeightRequest="14"
                        BackgroundColor="{Binding TaskColor}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 7"
                        VerticalOptions="Start"
                        Margin="0,4,0,0"/>
                </Grid>

                <!-- Metadata chips -->
                <HorizontalStackLayout Spacing="16">
                    <HorizontalStackLayout Spacing="4">
                        <Label
                            Text="Due"
                            FontSize="12"
                            FontFamily="OpenSansSemibold"
                            TextColor="{AppThemeBinding Light=#AEAEB2, Dark=#636366}"/>
                        <Label
                            Text="{Binding DueDate}"
                            FontSize="12"
                            FontFamily="OpenSansRegular"
                            TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                    </HorizontalStackLayout>

                    <Label
                        Text="{Binding Category}"
                        FontSize="12"
                        FontFamily="OpenSansSemibold"
                        TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>

            <!-- Action buttons row -->
            <Grid
                Grid.Row="1"
                Grid.Column="1"
                ColumnDefinitions="*,*,*,*"
                ColumnSpacing="8"
                Padding="16,0,16,14">

                <Button
                    Text="View"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewTaskCommand}"
                    CommandParameter="{Binding .}"
                    BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}"
                    TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"
                    CornerRadius="10"
                    HeightRequest="36"
                    FontSize="13"
                    FontFamily="OpenSansSemibold"
                    Padding="8,0"/>

                <Button
                    Grid.Column="1"
                    Text="Edit"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditTaskCommand}"
                    CommandParameter="{Binding .}"
                    BackgroundColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="36"
                    FontSize="13"
                    FontFamily="OpenSansSemibold"
                    Padding="8,0"/>

                <Button
                    Grid.Column="2"
                    Text="Done"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CompleteTaskCommand}"
                    CommandParameter="{Binding .}"
                    BackgroundColor="{AppThemeBinding Light=#E8FAF0, Dark=#0D3B1F}"
                    TextColor="{AppThemeBinding Light=#34C759, Dark=#30D158}"
                    CornerRadius="10"
                    HeightRequest="36"
                    FontSize="13"
                    FontFamily="OpenSansSemibold"
                    Padding="8,0">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsCompleted}" Value="True">
                            <Setter Property="Text" Value="Completed"/>
                            <Setter Property="IsEnabled" Value="False"/>
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E8FAF0, Dark=#0D3B1F}"/>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#34C759, Dark=#30D158}"/>
                            <Setter Property="Opacity" Value="0.6"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button
                    Grid.Column="3"
                    Text="Delete"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"
                    CommandParameter="{Binding .}"
                    BackgroundColor="{AppThemeBinding Light=#FFF0EF, Dark=#3B1A18}"
                    TextColor="{AppThemeBinding Light=#FF3B30, Dark=#FF6961}"
                    CornerRadius="10"
                    HeightRequest="36"
                    FontSize="13"
                    FontFamily="OpenSansSemibold"
                    Padding="8,0"/>

            </Grid>
        </Grid>
    </Frame>
</ContentView>