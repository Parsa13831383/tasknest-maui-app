<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="TaskNest.Controls.TaskCard"
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Frame
        Padding="18"
        Margin="0,0,0,14"
        CornerRadius="18"
        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A2230}"
        BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#2B3240}"
        HasShadow="True">

        <VerticalStackLayout Spacing="12">

            <!-- Title + Color -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="{Binding Title}"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                    <Label
                        Text="{Binding Description}"
                        FontSize="14"
                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                </VerticalStackLayout>

                <Border
                    Grid.Column="1"
                    WidthRequest="16"
                    HeightRequest="16"
                    BackgroundColor="{Binding TaskColor}"
                    Stroke="#D1D5DB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    VerticalOptions="Center"/>
            </Grid>

            <!-- Metadata -->
            <Grid ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="10">
                <Label
                    Text="Due:"
                    FontSize="13"
                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>

                <Label
                    Grid.Column="1"
                    Text="{Binding DueDate}"
                    FontSize="13"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                <Label
                    Grid.Column="2"
                    Text="{Binding Category}"
                    FontSize="13"
                    TextColor="#2563EB"/>
            </Grid>

            <!-- Actions -->
                <Grid ColumnDefinitions="*,*,*"
                    ColumnSpacing="12">

                <Button
                    Text="View Details"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewTaskCommand}"
                    CommandParameter="{Binding .}"
                    BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#1F2937}"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"
                    CornerRadius="12"
                    HeightRequest="42"/>

                <Button
                    Grid.Column="1"
                    Text="Edit Task"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditTaskCommand}"
                    CommandParameter="{Binding .}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="42"/>

                <Button
                    Grid.Column="2"
                    Text="Delete"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"
                    CommandParameter="{Binding .}"
                    BackgroundColor="#FEE2E2"
                    TextColor="#B91C1C"
                    CornerRadius="12"
                    HeightRequest="42"/>

            </Grid>

        </VerticalStackLayout>
    </Frame>
</ContentView>