<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="TaskNest.Controls.TaskCard"
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:TaskNest.Controls">

    <Border
        Padding="12"
        StrokeThickness="1"
        Stroke="#2B2B2B"
        BackgroundColor="#1E1E1E"
        StrokeShape="RoundRectangle 14">

        <Grid RowDefinitions="Auto,Auto"
                ColumnDefinitions="*,Auto"
                RowSpacing="6">
            <!-- Title + optional icon -->
            <HorizontalStackLayout Spacing="8">
                <!-- optional icon -->
                <Image
                    Source="{Binding Icon, Source={x:Reference This}}"
                    HeightRequest="18"
                    WidthRequest="18"
                    IsVisible="{Binding HasIcon, Source={x:Reference This}}"/>

                <Label
                    FontAttributes="Bold"
                    FontSize="16"
                    TextColor="White"
                    LineBreakMode="TailTruncation"
                    Text="{Binding Title, Source={x:Reference This}}"/>
            </HorizontalStackLayout>

            <!-- Priority badge -->
            <controls:PriorityBadge
                Grid.Column="1"
                Text="{Binding PriorityText, Source={x:Reference This}}"
                BadgeColor="{Binding PriorityColor, Source={x:Reference This}}"/>

            <!-- Subtitle -->
            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                FontSize="13"
                TextColor="#BDBDBD"
                LineBreakMode="TailTruncation"
                Text="{Binding Subtitle, Source={x:Reference This}}"/>
        </Grid>
    </Border>
</ContentView>