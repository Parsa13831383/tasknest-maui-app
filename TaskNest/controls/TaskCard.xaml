<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="TaskNest.Controls.TaskCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:TaskNest.Controls">

    <Frame
        Padding="18"
        Margin="0,0,0,14"
        CornerRadius="18"
        BackgroundColor="White"
        HasShadow="True">

        <VerticalStackLayout Spacing="12">

            <!-- Title + Priority -->
            <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="{Binding Title}"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#111827"/>

                    <Label
                        Text="{Binding Description}"
                        FontSize="14"
                        TextColor="#6B7280"/>
                </VerticalStackLayout>

                <controls:PriorityBadge
                    Grid.Column="1"
                    PriorityText="{Binding PriorityText}"
                    PriorityColor="{Binding PriorityColor}"/>
            </Grid>

            <!-- Metadata -->
            <Grid ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="10">
                <Label
                    Text="Due:"
                    FontSize="13"
                    TextColor="#6B7280"/>

                <Label
                    Grid.Column="1"
                    Text="{Binding DueDate}"
                    FontSize="13"
                    TextColor="#111827"/>

                <Label
                    Grid.Column="2"
                    Text="{Binding Category}"
                    FontSize="13"
                    TextColor="#2563EB"/>
            </Grid>

            <!-- Actions -->
            <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="12">

                <Button
                    Text="View Details"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewTaskCommand}"
                    CommandParameter="{Binding .}"
                    BackgroundColor="#E5E7EB"
                    TextColor="#111827"
                    CornerRadius="12"
                    HeightRequest="42"/>

                <Button
                    Grid.Column="1"
                    Text="Edit Task"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditTaskCommand}"
                    CommandParameter="{Binding .}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="42"/>

            </Grid>

        </VerticalStackLayout>
    </Frame>
</ContentView>