<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:SettingsViewModel"
    Title="Settings"
    BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

    <ScrollView>
        <VerticalStackLayout Padding="20,32,20,24"
                Spacing="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Settings"
                    Style="{StaticResource PageTitle}"/>

                <Label
                    Text="Manage your app preferences and account experience."
                    Style="{StaticResource PageSubtitle}"/>
            </VerticalStackLayout>

            <!-- Preferences Card -->
            <Frame
                Padding="20"
                CornerRadius="16"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                HasShadow="False">
                <VerticalStackLayout Spacing="20">

                    <Label
                        Text="Preferences"
                        Style="{StaticResource SectionTitle}"/>

                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="20"
                          ColumnSpacing="16">
                        <VerticalStackLayout Grid.Row="0"
                                Grid.Column="0"
                                Spacing="4">
                            <Label
                                Text="Enable Notifications"
                                FontSize="16"
                                FontFamily="OpenSansSemibold"
                                TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                            <Label
                                Text="Receive reminders about task deadlines."
                                Style="{StaticResource Caption}"/>
                        </VerticalStackLayout>
                        <Switch
                            Grid.Row="0"
                            Grid.Column="1"
                            IsToggled="{Binding NotificationsEnabled}"
                            VerticalOptions="Center"/>

                        <VerticalStackLayout Grid.Row="1"
                                Grid.Column="0"
                                Spacing="4">
                            <Label
                                Text="Dark Mode"
                                FontSize="16"
                                FontFamily="OpenSansSemibold"
                                TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                            <Label
                                Text="Toggle a darker appearance for the app."
                                Style="{StaticResource Caption}"/>
                        </VerticalStackLayout>
                        <Switch
                            Grid.Row="1"
                            Grid.Column="1"
                            IsToggled="{Binding DarkModeEnabled}"
                            VerticalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- Appearance & Language Card -->
            <Frame
                Padding="20"
                CornerRadius="16"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                HasShadow="False">
                <VerticalStackLayout Spacing="18">

                    <Label
                        Text="Appearance &amp; Language"
                        Style="{StaticResource SectionTitle}"/>

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Theme"
                            Style="{StaticResource FieldLabel}"/>
                        <Picker
                            Title="Select theme"
                            ItemsSource="{Binding Themes}"
                            SelectedItem="{Binding SelectedTheme}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Language"
                            Style="{StaticResource FieldLabel}"/>
                        <Picker
                            Title="Select language"
                            ItemsSource="{Binding Languages}"
                            SelectedItem="{Binding SelectedLanguage}"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Productivity Card -->
            <Frame
                Padding="20"
                CornerRadius="16"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                HasShadow="False">
                <VerticalStackLayout Spacing="18">

                    <Label
                        Text="Productivity"
                        Style="{StaticResource SectionTitle}"/>

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Reminder Frequency"
                            Style="{StaticResource FieldLabel}"/>
                        <Picker
                            Title="Choose reminder frequency"
                            ItemsSource="{Binding ReminderFrequencies}"
                            SelectedItem="{Binding SelectedReminderFrequency}"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Save / Reset Buttons -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10">
                <Button
                    Grid.Column="0"
                    Text="Save Settings"
                    Command="{Binding SaveSettingsCommand}"
                    Style="{StaticResource PrimaryButton}"/>

                <Button
                    Grid.Column="1"
                    Text="Reset"
                    Command="{Binding ResetSettingsCommand}"
                    Style="{StaticResource SecondaryButton}"/>
            </Grid>

            <!-- Account / Logout Card -->
            <Frame
                Padding="20"
                CornerRadius="16"
                BackgroundColor="{AppThemeBinding Light=#FFF0EF, Dark=#3B1A18}"
                BorderColor="{AppThemeBinding Light=#FECDD3, Dark=#5B2428}"
                HasShadow="False">
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="Account"
                        FontSize="18"
                        FontFamily="OpenSansSemibold"
                        TextColor="{AppThemeBinding Light=#FF3B30, Dark=#FF6961}"/>

                    <Label
                        Text="Sign out of your account on this device."
                        Style="{StaticResource Caption}"
                        TextColor="{AppThemeBinding Light=#FF3B30, Dark=#FF6961}"/>

                    <Button
                        Text="Logout"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource DestructiveButton}"
                        HeightRequest="46"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Security Proof Card -->
            <Frame
                Padding="20"
                CornerRadius="16"
                BackgroundColor="{AppThemeBinding Light=#E8FAF0, Dark=#0D3B1F}"
                BorderColor="{AppThemeBinding Light=#A7F3D0, Dark=#1F4D3B}"
                HasShadow="False">
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="Security Proof"
                        FontSize="18"
                        FontFamily="OpenSansSemibold"
                        TextColor="{AppThemeBinding Light=#166534, Dark=#6EE7B7}"/>

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="8"
                          ColumnSpacing="12">
                        <Label Grid.Row="0" Grid.Column="0" Text="User ID:" FontFamily="OpenSansSemibold" FontSize="13" TextColor="{AppThemeBinding Light=#166534, Dark=#6EE7B7}"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding SecurityUserId}" FontSize="13" TextColor="{AppThemeBinding Light=#14532D, Dark=#D1FAE5}"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="Auth State:" FontFamily="OpenSansSemibold" FontSize="13" TextColor="{AppThemeBinding Light=#166534, Dark=#6EE7B7}"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding SecurityAuthState}" FontSize="13" TextColor="{AppThemeBinding Light=#14532D, Dark=#D1FAE5}"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="Token Exists:" FontFamily="OpenSansSemibold" FontSize="13" TextColor="{AppThemeBinding Light=#166534, Dark=#6EE7B7}"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding SecurityTokenState}" FontSize="13" TextColor="{AppThemeBinding Light=#14532D, Dark=#D1FAE5}"/>
                    </Grid>

                    <Button
                        Text="Refresh Security Proof"
                        Command="{Binding RefreshSecurityProofCommand}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#123125}"
                        TextColor="{AppThemeBinding Light=#166534, Dark=#A7F3D0}"
                        BorderColor="{AppThemeBinding Light=#86EFAC, Dark=#1F4D3B}"
                        BorderWidth="1"
                        CornerRadius="12"
                        HeightRequest="42"/>
                </VerticalStackLayout>
            </Frame>

            <!-- RLS Demo Script Card -->
            <Frame
                Padding="20"
                CornerRadius="16"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="RLS Multi-User Demo Script"
                        FontSize="18"
                        FontFamily="OpenSansSemibold"
                        TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                    <Label
                        Text="1. Create and log in as User A, then create a task named 'A-only task'."
                        Style="{StaticResource Caption}"
                        TextColor="{AppThemeBinding Light=#48484A, Dark=#D1D1D6}"/>
                    <Label
                        Text="2. Log out, create/login as User B, and open Tasks."
                        Style="{StaticResource Caption}"
                        TextColor="{AppThemeBinding Light=#48484A, Dark=#D1D1D6}"/>
                    <Label
                        Text="3. Verify 'A-only task' is not visible for User B (RLS isolation proof)."
                        Style="{StaticResource Caption}"
                        TextColor="{AppThemeBinding Light=#48484A, Dark=#D1D1D6}"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>