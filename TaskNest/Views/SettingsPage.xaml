<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:SettingsViewModel"
    Title="Settings"
    BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="22">

            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Settings"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="#111827"/>

                <Label
                    Text="Manage your app preferences and account experience."
                    FontSize="15"
                    TextColor="#6B7280"/>
            </VerticalStackLayout>

            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="White"
                HasShadow="True">
                <VerticalStackLayout Spacing="18">

                    <Label
                        Text="Preferences"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#111827"/>

                    <Grid ColumnDefinitions="*,Auto"
                            RowDefinitions="Auto,Auto"
                            RowSpacing="18"
                            ColumnSpacing="12">
                        <VerticalStackLayout Grid.Row="0"
                                Grid.Column="0"
                                Spacing="4">
                            <Label
                                Text="Enable Notifications"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Label
                                Text="Receive reminders about task deadlines."
                                FontSize="14"
                                TextColor="#6B7280"/>
                        </VerticalStackLayout>
                        <Switch
                            Grid.Row="0"
                            Grid.Column="1"
                            IsToggled="{Binding NotificationsEnabled}"
                            OnColor="#2563EB"/>

                        <VerticalStackLayout Grid.Row="1"
                                Grid.Column="0"
                                Spacing="4">
                            <Label
                                Text="Dark Mode"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Label
                                Text="Toggle a darker appearance for the app."
                                FontSize="14"
                                TextColor="#6B7280"/>
                        </VerticalStackLayout>
                        <Switch
                            Grid.Row="1"
                            Grid.Column="1"
                            IsToggled="{Binding DarkModeEnabled}"
                            OnColor="#2563EB"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="White"
                HasShadow="True">
                <VerticalStackLayout Spacing="18">

                    <Label
                        Text="Appearance &amp; Language"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#111827"/>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Theme"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#111827"/>
                        <Picker
                            Title="Select theme"
                            ItemsSource="{Binding Themes}"
                            SelectedItem="{Binding SelectedTheme}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Language"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#111827"/>
                        <Picker
                            Title="Select language"
                            ItemsSource="{Binding Languages}"
                            SelectedItem="{Binding SelectedLanguage}"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="White"
                HasShadow="True">
                <VerticalStackLayout Spacing="18">

                    <Label
                        Text="Productivity"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#111827"/>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Default Task Priority"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#111827"/>
                        <Picker
                            Title="Choose default priority"
                            ItemsSource="{Binding Priorities}"
                            SelectedItem="{Binding SelectedDefaultPriority}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Reminder Frequency"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#111827"/>
                        <Picker
                            Title="Choose reminder frequency"
                            ItemsSource="{Binding ReminderFrequencies}"
                            SelectedItem="{Binding SelectedReminderFrequency}"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="14">
                <Button
                    Grid.Column="0"
                    Text="Save Settings"
                    Command="{Binding SaveSettingsCommand}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="50"/>

                <Button
                    Grid.Column="1"
                    Text="Reset"
                    Command="{Binding ResetSettingsCommand}"
                    BackgroundColor="#E5E7EB"
                    TextColor="#111827"
                    CornerRadius="12"
                    HeightRequest="50"/>
            </Grid>

            <Frame
                Padding="18"
                CornerRadius="18"
                BackgroundColor="#FEF2F2"
                HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Account"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#991B1B"/>

                    <Label
                        Text="Sign out of your account on this device."
                        FontSize="14"
                        TextColor="#B91C1C"/>

                    <Button
                        Text="Logout"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="White"
                        TextColor="#DC2626"
                        BorderColor="#FCA5A5"
                        BorderWidth="1"
                        CornerRadius="12"
                        HeightRequest="48"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>