<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels;assembly=TaskNest"
    xmlns:controls="clr-namespace:TaskNest.Controls"
    x:DataType="viewModels:TaskListViewModel"
    Title="Tasks"
    BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

    <ScrollView>
        <VerticalStackLayout Padding="20,32,20,24"
                Spacing="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="{Binding PageTitle}"
                    Style="{StaticResource PageTitle}"/>

                <Label
                    Text="{Binding PageSubtitle}"
                    Style="{StaticResource PageSubtitle}"/>
            </VerticalStackLayout>

            <!-- Show All (when filtered by category) -->
            <Button
                Text="Show All Tasks"
                IsVisible="{Binding IsCategoryFiltered}"
                Command="{Binding ShowAllTasksCommand}"
                Style="{StaticResource GhostButton}"
                HorizontalOptions="Start"
                HeightRequest="36"
                FontSize="14"/>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10">
                <Button
                    Grid.Column="0"
                    Text="+ Create Task"
                    Command="{Binding CreateTaskCommand}"
                    Style="{StaticResource PrimaryButton}"
                    HeightRequest="48"/>

                <Button
                    Grid.Column="1"
                    Text="{Binding FilterButtonText}"
                    Command="{Binding FilterTasksCommand}"
                    Style="{StaticResource SecondaryButton}"
                    HeightRequest="48"/>
            </Grid>

            <!-- Search & Filter Card -->
            <Frame
                Padding="18"
                CornerRadius="16"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                HasShadow="False">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Text="Search &amp; Filters"
                        Style="{StaticResource SectionTitle}"
                        FontSize="18"/>

                    <Entry
                        Text="{Binding SearchQuery, Mode=TwoWay}"
                        Placeholder="Search tasks..."/>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Picker
                            Grid.Column="0"
                            ItemsSource="{Binding CategoryFilters}"
                            SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}"
                            Title="Category"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Task List -->
            <VerticalStackLayout Spacing="14">
                <Label
                    Text="Your Tasks"
                    Style="{StaticResource SectionTitle}"/>

                <CollectionView
                    ItemsSource="{Binding Tasks}"
                    SelectionMode="None">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Padding="32,48"
                            Spacing="10">
                            <Label
                                Text="No tasks yet"
                                FontSize="18"
                                FontFamily="OpenSansSemibold"
                                HorizontalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light=#8E8E93, Dark=#98989D}"/>
                            <Label
                                Text="Tap '+ Create Task' to get started."
                                Style="{StaticResource Caption}"
                                HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TaskListItem">
                            <controls:TaskCard
                                TaskId="{Binding Id}"
                                Title="{Binding Title}"
                                Subtitle="{Binding Description}"
                                DueDate="{Binding DueDate}"
                                Category="{Binding Category}"
                                TaskColor="{Binding TaskColor}"
                                ViewTaskCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewTaskCommand}"
                                EditTaskCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditTaskCommand}"
                                DeleteTaskCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>