<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels;assembly=TaskNest"
    xmlns:controls="clr-namespace:TaskNest.Controls"
    x:DataType="viewModels:TaskListViewModel"
    Title="Tasks"
    BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Tasks"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="#111827"/>

                <Label
                    Text="Manage your workload, track priorities, and stay organised."
                    FontSize="15"
                    TextColor="#6B7280"/>
            </VerticalStackLayout>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    Text="+ Create Task"
                    Command="{Binding CreateTaskCommand}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="48"/>

                <Button
                    Grid.Column="1"
                    Text="Filter Tasks"
                    BackgroundColor="#E5E7EB"
                    TextColor="#111827"
                    CornerRadius="12"
                    HeightRequest="48"/>
            </Grid>

            <!-- Search / Filter Area -->
            <Frame
                Padding="18"
                CornerRadius="18"
                BackgroundColor="White"
                HasShadow="True">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Text="Search &amp; Filters"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#111827"/>

                    <Entry
                        Placeholder="Search tasks..."
                        BackgroundColor="#F3F4F6"
                        TextColor="#111827"/>

                    <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12">
                        <Picker
                            Grid.Column="0"
                            Title="Priority"/>

                        <Picker
                            Grid.Column="1"
                            Title="Category"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Task List -->
            <VerticalStackLayout Spacing="12">
                <Label
                    Text="Your Tasks"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="#111827"/>

                <CollectionView
                    ItemsSource="{Binding Tasks}"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TaskListItem">
                            <controls:TaskCard
                                TaskId="{Binding Id}"
                                Title="{Binding Title}"
                                Subtitle="{Binding Description}"
                                DueDate="{Binding DueDate}"
                                Category="{Binding Category}"
                                PriorityText="{Binding PriorityText}"
                                PriorityColor="{Binding PriorityColor}"
                                ViewTaskCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewTaskCommand}"
                                EditTaskCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditTaskCommand}"
                                DeleteTaskCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>