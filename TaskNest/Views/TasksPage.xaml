<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels;assembly=TaskNest"
    xmlns:controls="clr-namespace:TaskNest.Controls"
    x:DataType="viewModels:TaskListViewModel"
    Title="Tasks"
    BackgroundColor="{AppThemeBinding Light=#F7F8FC, Dark=#0F141B}">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="{Binding PageTitle}"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                <Label
                    Text="{Binding PageSubtitle}"
                    FontSize="15"
                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
            </VerticalStackLayout>

            <!-- Show All button (visible when filtered by category) -->
            <Button
                Text="← Show All Tasks"
                IsVisible="{Binding IsCategoryFiltered}"
                Command="{Binding ShowAllTasksCommand}"
                BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#1F2937}"
                TextColor="{AppThemeBinding Light=#2563EB, Dark=#60A5FA}"
                CornerRadius="12"
                HeightRequest="40"
                FontSize="14"/>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    Text="+ Create Task"
                    Command="{Binding CreateTaskCommand}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="48"/>

                <Button
                    Grid.Column="1"
                    Text="{Binding FilterButtonText}"
                    Command="{Binding FilterTasksCommand}"
                    BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#1F2937}"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"
                    CornerRadius="12"
                    HeightRequest="48"/>
            </Grid>

            <!-- Search / Filter Area -->
            <Frame
                Padding="18"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A2230}"
                BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#2B3240}"
                HasShadow="True">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Text="Search &amp; Filters"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                    <Entry
                        Text="{Binding SearchQuery, Mode=TwoWay}"
                        Placeholder="Search tasks..."
                        BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#111827}"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                    <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12">
                        <Picker
                            Grid.Column="0"
                            ItemsSource="{Binding CategoryFilters}"
                            SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}"
                            BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#111827}"
                            TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"
                            Title="Category"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Task List -->
            <VerticalStackLayout Spacing="12">
                <Label
                    Text="Your Tasks"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                <CollectionView
                    ItemsSource="{Binding Tasks}"
                    SelectionMode="None">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Padding="24"
                            Spacing="8">
                            <Label
                                Text="No tasks yet"
                                FontSize="18"
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                            <Label
                                Text="Tap '+ Create Task' to get started."
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TaskListItem">
                            <controls:TaskCard
                                TaskId="{Binding Id}"
                                Title="{Binding Title}"
                                Subtitle="{Binding Description}"
                                DueDate="{Binding DueDate}"
                                Category="{Binding Category}"
                                TaskColor="{Binding TaskColor}"
                                ViewTaskCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewTaskCommand}"
                                EditTaskCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditTaskCommand}"
                                DeleteTaskCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>