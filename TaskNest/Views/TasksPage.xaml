<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:TaskNest.Controls">

    <ContentPage.Content>
        <CollectionView
            ItemsSource="{Binding Tasks}"
            Margin="16"
            SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <controls:TaskCard
                        Title="{Binding Title}"
                        Subtitle="{Binding Description}"
                        PriorityText="{Binding Priority}"
                        PriorityColor="{Binding PriorityColor}"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </ContentPage.Content>
</ContentPage>