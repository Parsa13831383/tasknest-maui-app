<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:DashboardViewModel"
    Title="Dashboard"
    BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="24">

            <VerticalStackLayout Spacing="6">
                <Label
                    Text="WELCOME BACK"
                    FontSize="16"
                    TextColor="#6B7280"/>

                <Label
                    Text="TaskNest Dashboard"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="#111827"/>

                <Label
                    Text="Stay on top of your tasks, priorities, and progress."
                    FontSize="15"
                    TextColor="#6B7280"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*,*"
                    ColumnSpacing="14">
                <Frame
                    Grid.Column="0"
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="#EEF4FF"
                    BorderColor="#4F7CFF"
                    HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Today"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#2563EB"/>
                        <Label Text="{Binding TodayTaskCount}"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                        <Label Text="Tasks"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                        <Label Text="{Binding HighPrioritySummary}"
                                FontSize="14"
                                TextColor="#6B7280"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Column="1"
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="White"
                    HasShadow="False"
                    BorderColor="#E5E7EB">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Completed"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                        <Label Text="{Binding CompletedThisWeek}"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                        <Label Text="This week"
                                FontSize="14"
                                TextColor="#6B7280"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Column="2"
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="White"
                    HasShadow="False"
                    BorderColor="#E5E7EB">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Categories"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                        <Label Text="{Binding CategoryCount}"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                        <Label Text="{Binding CategorySummary}"
                                FontSize="14"
                                TextColor="#2563EB"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="White"
                HasShadow="False"
                BorderColor="#E5E7EB">
                <VerticalStackLayout Spacing="16">
                    <Label
                        Text="Quick Actions"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#111827"/>

                    <HorizontalStackLayout Spacing="12">
                        <Button
                            Text="+ New Task"
                            Command="{Binding NewTaskCommand}"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="52"
                            Padding="18,0"/>

                        <Button
                            Text="View Tasks"
                            Command="{Binding ViewTasksCommand}"
                            BackgroundColor="#E5E7EB"
                            TextColor="#111827"
                            CornerRadius="14"
                            HeightRequest="52"
                            Padding="18,0"/>

                        <Button
                            Text="Categories"
                            Command="{Binding ViewCategoriesCommand}"
                            BackgroundColor="#E5E7EB"
                            TextColor="#111827"
                            CornerRadius="14"
                            HeightRequest="52"
                            Padding="18,0"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="White"
                HasShadow="False"
                BorderColor="#E5E7EB">
                <VerticalStackLayout Spacing="16">
                    <Label
                        Text="Today's Focus"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#111827"/>

                    <CollectionView ItemsSource="{Binding FocusItems}"
                            SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:FocusItem">
                                <Frame
                                    Padding="16"
                                    Margin="0,0,0,12"
                                    CornerRadius="16"
                                    HasShadow="False"
                                    BackgroundColor="#FAFAFA"
                                    BorderColor="#E5E7EB">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                            ColumnSpacing="14">
                                        <BoxView
                                            WidthRequest="4"
                                            HeightRequest="56"
                                            Color="{Binding AccentColor}"
                                            CornerRadius="2"
                                            VerticalOptions="Center"/>

                                        <VerticalStackLayout Grid.Column="1"
                                                Spacing="4">
                                            <Label
                                                Text="{Binding Title}"
                                                FontSize="17"
                                                FontAttributes="Bold"
                                                TextColor="#111827"/>
                                            <Label
                                                Text="{Binding Subtitle}"
                                                FontSize="14"
                                                TextColor="#6B7280"/>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="2"
                                                Spacing="4"
                                                HorizontalOptions="End">
                                            <Label
                                                Text="{Binding TimeLabel}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="#2563EB"
                                                HorizontalTextAlignment="End"/>
                                            <Label
                                                Text="{Binding MetaLabel}"
                                                FontSize="14"
                                                TextColor="#6B7280"
                                                HorizontalTextAlignment="End"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>