<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:DashboardViewModel"
    Title="Dashboard"
    BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

    <ScrollView>
        <VerticalStackLayout Padding="20,32,20,24"
                Spacing="24">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="{Binding WelcomeHeading}"
                    Style="{StaticResource Eyebrow}"/>

                <Label
                    Text="{Binding WelcomeTitle}"
                    Style="{StaticResource PageTitle}"/>

                <Label
                    Text="{Binding WelcomeSubtitle}"
                    Style="{StaticResource PageSubtitle}"/>

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    HeightRequest="28"
                    HorizontalOptions="Start"/>

                <Label
                    Text="{Binding ErrorMessage}"
                    IsVisible="{Binding HasError}"
                    Style="{StaticResource ErrorText}"
                    FontSize="14"/>
            </VerticalStackLayout>

            <!-- Summary Cards -->
            <Grid ColumnDefinitions="*,*,*"
                  ColumnSpacing="12">

                <!-- Active Tasks -->
                <Frame
                    Grid.Column="0"
                    Padding="16"
                    CornerRadius="18"
                    BackgroundColor="{AppThemeBinding Light=#E9F2FF, Dark=#0D2137}"
                    BorderColor="{AppThemeBinding Light=#C7DBFF, Dark=#1A3A5C}"
                    HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Active"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"/>
                        <Label Text="{Binding TodayTaskCount}"
                               Style="{StaticResource StatValue}"/>
                        <Label Text="Tasks"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                        <Label Text="{Binding TodayCardSubtitle}"
                               Style="{StaticResource Caption}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Completed -->
                <Frame
                    Grid.Column="1"
                    Padding="16"
                    CornerRadius="18"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                    HasShadow="False"
                    BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Completed"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                        <Label Text="{Binding CompletedTaskCount}"
                               Style="{StaticResource StatValue}"/>
                        <Label Text="{Binding CompletedSubtitle}"
                               Style="{StaticResource Caption}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Categories -->
                <Frame
                    Grid.Column="2"
                    Padding="16"
                    CornerRadius="18"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                    HasShadow="False"
                    BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Categories"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                        <Label Text="{Binding CategoryCount}"
                               Style="{StaticResource StatValue}"/>
                        <Label Text="{Binding CategorySummary}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Quick Actions Card -->
            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                HasShadow="False"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}">
                <VerticalStackLayout Spacing="16">
                    <Label
                        Text="Quick Actions"
                        Style="{StaticResource SectionTitle}"/>

                    <FlexLayout
                        Wrap="Wrap"
                        JustifyContent="Start"
                        AlignItems="Center">
                        <Button
                            Text="+ New Task"
                            Command="{Binding NewTaskCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HeightRequest="48"
                            Margin="0,0,10,10"/>

                        <Button
                            Text="View Tasks"
                            Command="{Binding ViewTasksCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HeightRequest="48"
                            Margin="0,0,10,10"/>

                        <Button
                            Text="Categories"
                            Command="{Binding ViewCategoriesCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HeightRequest="48"
                            Margin="0,0,10,10"/>

                        <Button
                            Text="Completed"
                            Command="{Binding ViewCompletedTasksCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HeightRequest="48"
                            Margin="0,0,10,10"/>
                    </FlexLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Weekly Productivity Chart -->
            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                HasShadow="False"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Text="Weekly Productivity"
                        Style="{StaticResource SectionTitle}"/>

                    <Label
                        Text="{Binding WeeklyChartSummary}"
                        Style="{StaticResource Caption}"/>

                    <!-- Bar Chart -->
                    <CollectionView
                        ItemsSource="{Binding WeeklyChartBars}"
                        SelectionMode="None"
                        HeightRequest="130">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout
                                Orientation="Horizontal"
                                ItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:WeeklyChartBar">
                                <VerticalStackLayout
                                    Spacing="4"
                                    WidthRequest="38"
                                    VerticalOptions="End"
                                    HorizontalOptions="Center">

                                    <!-- Count label -->
                                    <Label
                                        Text="{Binding Count}"
                                        FontSize="11"
                                        FontFamily="OpenSansSemibold"
                                        HorizontalTextAlignment="Center"
                                        TextColor="{AppThemeBinding Light=#8E8E93, Dark=#98989D}"/>

                                    <!-- Bar -->
                                    <BoxView
                                        HeightRequest="{Binding BarHeight}"
                                        WidthRequest="24"
                                        Color="{Binding BarColor}"
                                        CornerRadius="6"
                                        HorizontalOptions="Center"/>

                                    <!-- Day label -->
                                    <Label
                                        Text="{Binding DayLabel}"
                                        FontSize="11"
                                        FontFamily="OpenSansSemibold"
                                        HorizontalTextAlignment="Center"
                                        TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Today's Focus Card -->
            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                HasShadow="False"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}">
                <VerticalStackLayout Spacing="16">
                    <Label
                        Text="Today's Focus"
                        Style="{StaticResource SectionTitle}"/>

                    <CollectionView ItemsSource="{Binding FocusItems}"
                            SelectionMode="None">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout
                                HorizontalOptions="Center"
                                Padding="16"
                                Spacing="8">
                                <Label
                                    Text="No focus tasks"
                                    FontSize="16"
                                    FontFamily="OpenSansSemibold"
                                    HorizontalTextAlignment="Center"
                                    TextColor="{AppThemeBinding Light=#8E8E93, Dark=#98989D}"/>
                                <Label
                                    Text="{Binding FocusEmptyStateText}"
                                    Style="{StaticResource Caption}"
                                    HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:FocusItem">
                                <Frame
                                    Padding="16"
                                    Margin="0,0,0,10"
                                    CornerRadius="14"
                                    HasShadow="False"
                                    BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#2C2C2E}"
                                    BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                            ColumnSpacing="14">
                                        <BoxView
                                            WidthRequest="4"
                                            HeightRequest="48"
                                            Color="{Binding AccentColor}"
                                            CornerRadius="2"
                                            VerticalOptions="Center"/>

                                        <VerticalStackLayout Grid.Column="1"
                                                Spacing="4"
                                                VerticalOptions="Center">
                                            <Label
                                                Text="{Binding Title}"
                                                FontSize="16"
                                                FontFamily="OpenSansSemibold"
                                                TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                                            <Label
                                                Text="{Binding Subtitle}"
                                                Style="{StaticResource Caption}"/>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="2"
                                                Spacing="4"
                                                HorizontalOptions="End"
                                                VerticalOptions="Center">
                                            <Label
                                                Text="{Binding TimeLabel}"
                                                FontSize="13"
                                                FontFamily="OpenSansSemibold"
                                                TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"
                                                HorizontalTextAlignment="End"/>
                                            <Label
                                                Text="{Binding MetaLabel}"
                                                Style="{StaticResource Caption}"
                                                HorizontalTextAlignment="End"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>