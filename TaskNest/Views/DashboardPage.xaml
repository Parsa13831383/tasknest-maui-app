<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:DashboardViewModel"
    Title="Dashboard"
    BackgroundColor="{AppThemeBinding Light=#F7F8FC, Dark=#0F141B}">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="24">

            <VerticalStackLayout Spacing="6">
                <Label
                    Text="{Binding WelcomeHeading}"
                    FontSize="16"
                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>

                <Label
                    Text="{Binding WelcomeTitle}"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                <Label
                    Text="{Binding WelcomeSubtitle}"
                    FontSize="15"
                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="#2563EB"
                    HeightRequest="28"
                    HorizontalOptions="Start" />

                <Label
                    Text="{Binding ErrorMessage}"
                    IsVisible="{Binding HasError}"
                    FontSize="14"
                    TextColor="#DC2626" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*,*"
                    ColumnSpacing="14">
                <Frame
                    Grid.Column="0"
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="{AppThemeBinding Light=#EEF4FF, Dark=#1E293B}"
                    BorderColor="{AppThemeBinding Light=#4F7CFF, Dark=#60A5FA}"
                    HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Active"
                                FontSize="14"
                                FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#2563EB, Dark=#60A5FA}"/>
                        <Label Text="{Binding TodayTaskCount}"
                                FontSize="24"
                                FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>
                        <Label Text="Tasks"
                                FontSize="16"
                                FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>
                        <Label Text="{Binding TodayCardSubtitle}"
                                FontSize="14"
                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Column="1"
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1A2230}"
                    HasShadow="False"
                    BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#2B3240}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Completed"
                                FontSize="14"
                                FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>
                        <Label Text="{Binding CompletedTaskCount}"
                                FontSize="24"
                                FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>
                        <Label Text="{Binding CompletedSubtitle}"
                                FontSize="14"
                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Column="2"
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1A2230}"
                    HasShadow="False"
                    BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#2B3240}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Categories"
                                FontSize="14"
                                FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>
                        <Label Text="{Binding CategoryCount}"
                                FontSize="24"
                                FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>
                        <Label Text="{Binding CategorySummary}"
                                FontSize="14"
                                TextColor="#2563EB"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A2230}"
                HasShadow="False"
                BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#2B3240}">
                <VerticalStackLayout Spacing="16">
                    <Label
                        Text="Quick Actions"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                    <HorizontalStackLayout Spacing="12">
                        <Button
                            Text="+ New Task"
                            Command="{Binding NewTaskCommand}"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="52"
                            Padding="18,0"/>

                        <Button
                            Text="View Tasks"
                            Command="{Binding ViewTasksCommand}"
                            BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#1F2937}"
                            TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"
                            CornerRadius="14"
                            HeightRequest="52"
                            Padding="18,0"/>

                        <Button
                            Text="Categories"
                            Command="{Binding ViewCategoriesCommand}"
                            BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#1F2937}"
                            TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"
                            CornerRadius="14"
                            HeightRequest="52"
                            Padding="18,0"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A2230}"
                HasShadow="False"
                BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#2B3240}">
                <VerticalStackLayout Spacing="16">
                    <Label
                        Text="Today's Focus"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                    <CollectionView ItemsSource="{Binding FocusItems}"
                            SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label
                                Text="{Binding FocusEmptyStateText}"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:FocusItem">
                                <Frame
                                    Padding="16"
                                    Margin="0,0,0,12"
                                    CornerRadius="16"
                                    HasShadow="False"
                                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#111827}"
                                    BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#2B3240}">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                            ColumnSpacing="14">
                                        <BoxView
                                            WidthRequest="4"
                                            HeightRequest="56"
                                            Color="{Binding AccentColor}"
                                            CornerRadius="2"
                                            VerticalOptions="Center"/>

                                        <VerticalStackLayout Grid.Column="1"
                                                Spacing="4">
                                            <Label
                                                Text="{Binding Title}"
                                                FontSize="17"
                                                FontAttributes="Bold"
                                                TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>
                                            <Label
                                                Text="{Binding Subtitle}"
                                                FontSize="14"
                                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="2"
                                                Spacing="4"
                                                HorizontalOptions="End">
                                            <Label
                                                Text="{Binding TimeLabel}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="#2563EB"
                                                HorizontalTextAlignment="End"/>
                                            <Label
                                                Text="{Binding MetaLabel}"
                                                FontSize="14"
                                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                                HorizontalTextAlignment="End"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>