<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Register"
    BackgroundColor="#F7F8FC">

    <ScrollView>
        <Grid Padding="24">
            <VerticalStackLayout
                MaximumWidthRequest="520"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="22">

                <!-- HEADER -->
                <VerticalStackLayout Spacing="6">
                    <Label
                        Text="Create account"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="#111827"/>

                    <Label
                        Text="Join TaskNest and manage your productivity."
                        FontSize="15"
                        TextColor="#6B7280"/>
                </VerticalStackLayout>

                <!-- FORM CARD -->
                <Frame
                    Padding="22"
                    CornerRadius="18"
                    BackgroundColor="White"
                    HasShadow="True">

                    <VerticalStackLayout Spacing="18">

                        <Label
                            Text="Register"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#111827"/>

                        <!-- NAME -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Full Name"
                                    FontAttributes="Bold"/>
                            <Entry
                                Placeholder="Enter your name"
                                Text="{Binding Name}"/>
                        </VerticalStackLayout>

                        <!-- EMAIL -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email"
                                    FontAttributes="Bold"/>
                            <Entry
                                Placeholder="Enter your email"
                                Keyboard="Email"
                                Text="{Binding Email}"/>
                        </VerticalStackLayout>

                        <!-- PASSWORD -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password"
                                    FontAttributes="Bold"/>
                            <Entry
                                Placeholder="Create password"
                                IsPassword="True"
                                Text="{Binding Password}"/>
                        </VerticalStackLayout>

                        <!-- CONFIRM -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Confirm Password"
                                    FontAttributes="Bold"/>
                            <Entry
                                Placeholder="Confirm password"
                                IsPassword="True"
                                Text="{Binding ConfirmPassword}"/>
                        </VerticalStackLayout>

                        <!-- BUTTONS -->
                        <Button
                            Text="Create Account"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"/>

                        <Button
                            Text="Already have an account? Login"
                            Command="{Binding NavigateToLoginCommand}"
                            BackgroundColor="#E5E7EB"
                            TextColor="#111827"
                            CornerRadius="12"
                            HeightRequest="50"/>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>