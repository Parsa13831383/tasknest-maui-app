<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Register">

    <ContentPage.Content>
        <StackLayout Padding="16" Spacing="12" VerticalOptions="Center">
            <Label Text="Register" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            <Entry Placeholder="Email" />
            <Entry Placeholder="Password" IsPassword="True" />
            <Entry Placeholder="Confirm Password" IsPassword="True" />
            <Button Text="Register" />
        </StackLayout>
    </ContentPage.Content>
</ContentPage>
