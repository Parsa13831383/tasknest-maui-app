<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:RegisterViewModel"
    Title="Register"
    BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

    <ScrollView>
        <Grid Padding="24,48,24,24">
            <VerticalStackLayout
                MaximumWidthRequest="480"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="28">

                <!-- Header -->
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Create account"
                        Style="{StaticResource PageTitle}"/>

                    <Label
                        Text="Join TaskNest and manage your productivity."
                        Style="{StaticResource PageSubtitle}"/>
                </VerticalStackLayout>

                <!-- Form Card -->
                <Frame
                    Padding="24"
                    CornerRadius="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                    BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="20">

                        <Label
                            Text="Register"
                            Style="{StaticResource SectionTitle}"/>

                        <!-- Auth Error -->
                        <Label
                            Text="{Binding AuthError}"
                            IsVisible="{Binding HasAuthError}"
                            Style="{StaticResource ErrorText}"
                            FontSize="13"/>

                        <!-- Name -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Full Name"
                                   Style="{StaticResource FieldLabel}"/>
                            <Entry
                                Placeholder="Enter your name"
                                Text="{Binding Name}"/>
                            <Label
                                Text="{Binding NameError}"
                                IsVisible="{Binding HasNameError}"
                                Style="{StaticResource ErrorText}"/>
                        </VerticalStackLayout>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email"
                                   Style="{StaticResource FieldLabel}"/>
                            <Entry
                                Placeholder="Enter your email"
                                Keyboard="Email"
                                Text="{Binding Email}"/>
                            <Label
                                Text="{Binding EmailError}"
                                IsVisible="{Binding HasEmailError}"
                                Style="{StaticResource ErrorText}"/>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password"
                                   Style="{StaticResource FieldLabel}"/>
                            <Entry
                                Placeholder="Create password"
                                IsPassword="True"
                                Text="{Binding Password}"/>
                            <Label
                                Text="{Binding PasswordError}"
                                IsVisible="{Binding HasPasswordError}"
                                Style="{StaticResource ErrorText}"/>
                            <Label
                                Text="Use 12+ characters with uppercase, lowercase, number, and symbol."
                                Style="{StaticResource Caption}"/>
                        </VerticalStackLayout>

                        <!-- Confirm -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Confirm Password"
                                   Style="{StaticResource FieldLabel}"/>
                            <Entry
                                Placeholder="Confirm password"
                                IsPassword="True"
                                Text="{Binding ConfirmPassword}"/>
                            <Label
                                Text="{Binding ConfirmPasswordError}"
                                IsVisible="{Binding HasConfirmPasswordError}"
                                Style="{StaticResource ErrorText}"/>
                        </VerticalStackLayout>

                        <!-- Loading -->
                        <HorizontalStackLayout
                            Spacing="10"
                            IsVisible="{Binding IsBusy}">
                            <ActivityIndicator
                                IsRunning="{Binding IsBusy}"/>
                            <Label
                                Text="Creating account..."
                                FontSize="14"
                                VerticalOptions="Center"
                                Style="{StaticResource Caption}"/>
                        </HorizontalStackLayout>

                        <!-- Buttons -->
                        <Button
                            Text="Create Account"
                            Command="{Binding RegisterCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource PrimaryButton}"/>

                        <Button
                            Text="Already have an account? Login"
                            Command="{Binding NavigateToLoginCommand}"
                            Style="{StaticResource SecondaryButton}"/>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>