<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.ResetPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Reset Password"
    BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

    <ScrollView>
        <Grid Padding="20,32,20,24">
            <VerticalStackLayout
                MaximumWidthRequest="520"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="20">

                <!-- Header -->
                <VerticalStackLayout Spacing="6">
                    <Label
                        Text="Set a new password"
                        Style="{StaticResource PageTitle}"/>

                    <Label
                        Text="Choose a new password for your TaskNest account."
                        Style="{StaticResource PageSubtitle}"/>
                </VerticalStackLayout>

                <!-- Form Card -->
                <Frame
                    Padding="20"
                    CornerRadius="16"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                    BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="18">

                        <Label
                            Text="Reset Password"
                            Style="{StaticResource SectionTitle}"/>

                        <!-- New Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="New Password"
                                Style="{StaticResource FieldLabel}"/>
                            <Entry
                                Placeholder="Enter a new password"
                                IsPassword="True"
                                Text="{Binding NewPassword}"/>
                            <Label
                                Text="Use 12+ characters with uppercase, lowercase, number, and symbol."
                                Style="{StaticResource Caption}"/>
                        </VerticalStackLayout>

                        <!-- Confirm Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Confirm Password"
                                Style="{StaticResource FieldLabel}"/>
                            <Entry
                                Placeholder="Confirm your new password"
                                IsPassword="True"
                                Text="{Binding ConfirmPassword}"/>
                        </VerticalStackLayout>

                        <!-- Error Message -->
                        <Label
                            Text="{Binding ErrorMessage}"
                            IsVisible="{Binding HasErrorMessage}"
                            Style="{StaticResource ErrorText}"/>

                        <!-- Loading Indicator -->
                        <HorizontalStackLayout
                            Spacing="10"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsBusy}">
                            <ActivityIndicator
                                IsRunning="{Binding IsBusy}"/>
                            <Label
                                Text="Updating password..."
                                VerticalOptions="Center"
                                Style="{StaticResource Caption}"/>
                        </HorizontalStackLayout>

                        <!-- Buttons -->
                        <Button
                            Text="Update Password"
                            Command="{Binding ResetPasswordCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource PrimaryButton}"/>

                        <Button
                            Text="Back to Login"
                            Command="{Binding NavigateToLoginCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource SecondaryButton}"/>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>