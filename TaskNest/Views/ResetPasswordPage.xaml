<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.ResetPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Reset Password"
    BackgroundColor="#F7F8FC">

    <ScrollView>
        <Grid Padding="24">
            <VerticalStackLayout
                MaximumWidthRequest="520"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="22">

                <VerticalStackLayout Spacing="6">
                    <Label
                        Text="Set a new password"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="#111827"/>

                    <Label
                        Text="Choose a new password for your TaskNest account."
                        FontSize="15"
                        TextColor="#6B7280"/>
                </VerticalStackLayout>

                <Frame
                    Padding="22"
                    CornerRadius="18"
                    BackgroundColor="White"
                    HasShadow="True">

                    <VerticalStackLayout Spacing="18">

                        <Label
                            Text="Reset Password"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#111827"/>

                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="New Password"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Entry
                                Placeholder="Enter a new password"
                                IsPassword="True"
                                Text="{Binding NewPassword}"
                                TextColor="#111827"
                                BackgroundColor="#F9FAFB"/>
                            <Label
                                Text="Use 12+ characters with uppercase, lowercase, number, and symbol."
                                FontSize="12"
                                TextColor="#6B7280"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Confirm Password"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Entry
                                Placeholder="Confirm your new password"
                                IsPassword="True"
                                Text="{Binding ConfirmPassword}"
                                TextColor="#111827"
                                BackgroundColor="#F9FAFB"/>
                        </VerticalStackLayout>

                        <Label
                            Text="{Binding ErrorMessage}"
                            IsVisible="{Binding HasErrorMessage}"
                            FontSize="13"
                            TextColor="#B91C1C"/>

                        <HorizontalStackLayout
                            Spacing="10"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsBusy}">
                            <ActivityIndicator
                                IsRunning="{Binding IsBusy}"
                                Color="#2563EB"/>
                            <Label
                                Text="Updating password..."
                                VerticalOptions="Center"
                                TextColor="#374151"/>
                        </HorizontalStackLayout>

                        <Button
                            Text="Update Password"
                            Command="{Binding ResetPasswordCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"/>

                        <Button
                            Text="Back to Login"
                            Command="{Binding NavigateToLoginCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="#E5E7EB"
                            TextColor="#111827"
                            CornerRadius="12"
                            HeightRequest="50"/>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>