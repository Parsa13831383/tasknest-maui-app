<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:ProfileViewModel"
    Title="Profile"
    BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

    <ScrollView>
        <VerticalStackLayout Padding="20,32,20,24"
                Spacing="24">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Profile"
                    Style="{StaticResource PageTitle}"/>

                <Label
                    Text="Manage your personal details and account overview."
                    Style="{StaticResource PageSubtitle}"/>
            </VerticalStackLayout>

            <!-- Profile Header Card -->
            <Frame
                Padding="24"
                CornerRadius="20"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                HasShadow="False">

                <VerticalStackLayout Spacing="20">

                    <!-- Avatar + Name -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                        <Frame
                            WidthRequest="72"
                            HeightRequest="72"
                            CornerRadius="36"
                            BackgroundColor="{AppThemeBinding Light=#E9F2FF, Dark=#0D2137}"
                            HasShadow="False"
                            Padding="0">
                            <Label
                                Text="{Binding Initials}"
                                FontSize="28"
                                FontFamily="OpenSansSemibold"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        </Frame>

                        <VerticalStackLayout Grid.Column="1" Spacing="6"
                                VerticalOptions="Center">
                            <Label
                                Text="{Binding FullName}"
                                FontSize="22"
                                FontFamily="OpenSansSemibold"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>

                            <Label
                                Text="{Binding Role}"
                                Style="{StaticResource Caption}"/>

                            <Frame
                                Padding="10,5"
                                CornerRadius="12"
                                HasShadow="False"
                                BackgroundColor="{AppThemeBinding Light=#E8FAF0, Dark=#0D3B1F}"
                                HorizontalOptions="Start">
                                <Label
                                    Text="{Binding SessionStatus}"
                                    FontSize="12"
                                    FontFamily="OpenSansSemibold"
                                    TextColor="{AppThemeBinding Light=#34C759, Dark=#30D158}"/>
                            </Frame>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                            Color="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"/>

                    <!-- Stats Row -->
                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="10">
                        <Frame
                            Grid.Column="0"
                            Padding="14"
                            CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#2C2C2E}"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label
                                    Text="{Binding CompletedTaskCount}"
                                    Style="{StaticResource StatValue}"
                                    FontSize="24"
                                    HorizontalTextAlignment="Center"/>
                                <Label
                                    Text="Completed"
                                    Style="{StaticResource StatLabel}"
                                    HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame
                            Grid.Column="1"
                            Padding="14"
                            CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#2C2C2E}"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label
                                    Text="{Binding ActiveTaskCount}"
                                    Style="{StaticResource StatValue}"
                                    FontSize="24"
                                    HorizontalTextAlignment="Center"/>
                                <Label
                                    Text="Active"
                                    Style="{StaticResource StatLabel}"
                                    HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame
                            Grid.Column="2"
                            Padding="14"
                            CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#2C2C2E}"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label
                                    Text="{Binding CategoryCount}"
                                    Style="{StaticResource StatValue}"
                                    FontSize="24"
                                    HorizontalTextAlignment="Center"/>
                                <Label
                                    Text="Categories"
                                    Style="{StaticResource StatLabel}"
                                    HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Account Details Card -->
            <Frame
                Padding="24"
                CornerRadius="20"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                HasShadow="False">

                <VerticalStackLayout Spacing="18">

                    <Label
                        Text="Account Details"
                        Style="{StaticResource SectionTitle}"/>

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Full Name"
                            Style="{StaticResource FieldLabel}"/>
                        <Entry
                            Text="{Binding FullName}"
                            IsReadOnly="True"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Email Address"
                            Style="{StaticResource FieldLabel}"/>
                        <Entry
                            Text="{Binding EmailAddress}"
                            IsReadOnly="True"
                            Keyboard="Email"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Role"
                            Style="{StaticResource FieldLabel}"/>
                        <Entry
                            Text="{Binding Role}"
                            IsReadOnly="True"/>
                    </VerticalStackLayout>

                    <Label
                        Text="{Binding ErrorMessage}"
                        IsVisible="{Binding HasErrorMessage}"
                        Style="{StaticResource ErrorText}"
                        FontSize="13"/>

                    <HorizontalStackLayout
                        Spacing="10"
                        VerticalOptions="Center"
                        IsVisible="{Binding IsBusy}">
                        <ActivityIndicator
                            IsRunning="{Binding IsBusy}"/>
                        <Label
                            Text="Loading profile..."
                            VerticalOptions="Center"
                            Style="{StaticResource Caption}"/>
                    </HorizontalStackLayout>

                    <!-- Actions -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button
                            Grid.Column="0"
                            Text="Read-only"
                            IsEnabled="False"
                            Style="{StaticResource PrimaryButton}"/>

                        <Button
                            Grid.Column="1"
                            Text="Refresh"
                            Command="{Binding LoadProfileCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource SecondaryButton}"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>