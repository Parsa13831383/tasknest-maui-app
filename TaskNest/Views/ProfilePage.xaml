<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Profile"
    BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="22">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Profile"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="#111827"/>

                <Label
                    Text="Manage your personal details and account overview."
                    FontSize="15"
                    TextColor="#6B7280"/>
            </VerticalStackLayout>

            <!-- Profile Card -->
            <Frame
                Padding="22"
                CornerRadius="18"
                BackgroundColor="White"
                HasShadow="True">

                <VerticalStackLayout Spacing="18">

                    <!-- Avatar + Basic Info -->
                    <HorizontalStackLayout Spacing="18">
                        <Frame
                            WidthRequest="84"
                            HeightRequest="84"
                            CornerRadius="42"
                            BackgroundColor="#DBEAFE"
                            HasShadow="False"
                            VerticalOptions="Start"
                            Padding="0">
                            <Grid>
                                <Label
                                    Text="P"
                                    FontSize="32"
                                    FontAttributes="Bold"
                                    TextColor="#1D4ED8"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            </Grid>
                        </Frame>

                        <VerticalStackLayout Spacing="6"
                                VerticalOptions="Center">
                            <Label
                                Text="Parsa Nanavazadeh"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="#111827"/>

                            <Label
                                Text="Student / TaskNest User"
                                FontSize="14"
                                TextColor="#6B7280"/>

                            <Frame
                                Padding="10,6"
                                CornerRadius="14"
                                HasShadow="False"
                                BackgroundColor="#DCFCE7"
                                HorizontalOptions="Start">
                                <Label
                                    Text="Active"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="#15803D"/>
                            </Frame>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1"
                            Color="#E5E7EB"/>

                    <!-- Stats Row -->
                    <Grid ColumnDefinitions="*,*,*"
                            ColumnSpacing="14">
                        <Frame
                            Grid.Column="0"
                            Padding="14"
                            CornerRadius="14"
                            BackgroundColor="#F9FAFB"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Completed"
                                    FontSize="13"
                                    TextColor="#6B7280"/>
                                <Label
                                    Text="12"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="#111827"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame
                            Grid.Column="1"
                            Padding="14"
                            CornerRadius="14"
                            BackgroundColor="#F9FAFB"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Active Tasks"
                                    FontSize="13"
                                    TextColor="#6B7280"/>
                                <Label
                                    Text="5"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="#111827"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame
                            Grid.Column="2"
                            Padding="14"
                            CornerRadius="14"
                            BackgroundColor="#F9FAFB"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Categories"
                                    FontSize="13"
                                    TextColor="#6B7280"/>
                                <Label
                                    Text="4"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="#111827"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <BoxView HeightRequest="1"
                            Color="#E5E7EB"/>

                    <!-- Form -->
                    <VerticalStackLayout Spacing="16">

                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Full Name"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Entry
                                Text="Parsa Nanavazadeh"
                                BackgroundColor="#F9FAFB"
                                TextColor="#111827"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Email Address"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Entry
                                Text="parsa@example.com"
                                Keyboard="Email"
                                BackgroundColor="#F9FAFB"
                                TextColor="#111827"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Role"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Entry
                                Text="Student Developer"
                                BackgroundColor="#F9FAFB"
                                TextColor="#111827"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Actions -->
                    <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="14">
                        <Button
                            Grid.Column="0"
                            Text="Save Changes"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"/>

                        <Button
                            Grid.Column="1"
                            Text="Edit Avatar"
                            BackgroundColor="#E5E7EB"
                            TextColor="#111827"
                            CornerRadius="12"
                            HeightRequest="50"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>