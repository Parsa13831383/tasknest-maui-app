<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Profile"
    BackgroundColor="{AppThemeBinding Light=#F7F8FC, Dark=#0F172A}">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="22">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Profile"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>

                <Label
                    Text="Manage your personal details and account overview."
                    FontSize="15"
                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
            </VerticalStackLayout>

            <!-- Profile Card -->
            <Frame
                Padding="22"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}"
                HasShadow="True">

                <VerticalStackLayout Spacing="18">

                    <!-- Avatar + Basic Info -->
                    <HorizontalStackLayout Spacing="18">
                        <Frame
                            WidthRequest="84"
                            HeightRequest="84"
                            CornerRadius="42"
                            BackgroundColor="{AppThemeBinding Light=#DBEAFE, Dark=#1E3A8A}"
                            HasShadow="False"
                            VerticalOptions="Start"
                            Padding="0">
                            <Grid>
                                <Label
                                    Text="P"
                                    FontSize="32"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light=#1D4ED8, Dark=#BFDBFE}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            </Grid>
                        </Frame>

                        <VerticalStackLayout Spacing="6"
                                VerticalOptions="Center">
                            <Label
                                Text="Parsa Nanavazadeh"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>

                            <Label
                                Text="Student / TaskNest User"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>

                            <Frame
                                Padding="10,6"
                                CornerRadius="14"
                                HasShadow="False"
                                BackgroundColor="{AppThemeBinding Light=#DCFCE7, Dark=#14532D}"
                                HorizontalOptions="Start">
                                <Label
                                    Text="Active"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light=#15803D, Dark=#BBF7D0}"/>
                            </Frame>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1"
                            Color="{AppThemeBinding Light=#E5E7EB, Dark=#334155}"/>

                    <!-- Stats Row -->
                    <Grid ColumnDefinitions="*,*,*"
                            ColumnSpacing="14">
                        <Frame
                            Grid.Column="0"
                            Padding="14"
                            CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1E293B}"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Completed"
                                    FontSize="13"
                                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                                <Label
                                    Text="12"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame
                            Grid.Column="1"
                            Padding="14"
                            CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1E293B}"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Active Tasks"
                                    FontSize="13"
                                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                                <Label
                                    Text="5"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame
                            Grid.Column="2"
                            Padding="14"
                            CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1E293B}"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Categories"
                                    FontSize="13"
                                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                                <Label
                                    Text="4"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <BoxView HeightRequest="1"
                            Color="{AppThemeBinding Light=#E5E7EB, Dark=#334155}"/>

                    <!-- Form -->
                    <VerticalStackLayout Spacing="16">

                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Full Name"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                            <Entry
                                Text="Parsa Nanavazadeh"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1E293B}"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Email Address"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                            <Entry
                                Text="parsa@example.com"
                                Keyboard="Email"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1E293B}"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Role"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                            <Entry
                                Text="Student Developer"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1E293B}"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Actions -->
                    <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="14">
                        <Button
                            Grid.Column="0"
                            Text="Save Changes"
                            BackgroundColor="{AppThemeBinding Light=#2563EB, Dark=#3B82F6}"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"/>

                        <Button
                            Grid.Column="1"
                            Text="Edit Avatar"
                            BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}"
                            TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"
                            CornerRadius="12"
                            HeightRequest="50"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>