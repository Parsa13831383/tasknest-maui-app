<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Login"
    BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

    <ScrollView>
        <Grid Padding="24,48,24,24">
            <VerticalStackLayout
                MaximumWidthRequest="480"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="28">

                <!-- Header -->
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Welcome back"
                        Style="{StaticResource Eyebrow}"/>

                    <Label
                        Text="Login to TaskNest"
                        Style="{StaticResource PageTitle}"/>

                    <Label
                        Text="Access your tasks, categories, and productivity dashboard."
                        Style="{StaticResource PageSubtitle}"/>
                </VerticalStackLayout>

                <!-- Form Card -->
                <Frame
                    Padding="24"
                    CornerRadius="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                    BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="20">

                        <Label
                            Text="Account Login"
                            Style="{StaticResource SectionTitle}"/>

                        <!-- Email Field -->
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Email Address"
                                Style="{StaticResource FieldLabel}"/>
                            <Entry
                                Placeholder="Enter your email"
                                Keyboard="Email"
                                Text="{Binding Email}"/>
                            <Label
                                Text="{Binding EmailError}"
                                IsVisible="{Binding HasEmailError}"
                                Style="{StaticResource ErrorText}"/>
                        </VerticalStackLayout>

                        <!-- Password Field -->
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Password"
                                Style="{StaticResource FieldLabel}"/>
                            <Entry
                                Placeholder="Enter your password"
                                IsPassword="True"
                                Text="{Binding Password}"/>
                            <Label
                                Text="{Binding PasswordError}"
                                IsVisible="{Binding HasPasswordError}"
                                Style="{StaticResource ErrorText}"/>
                        </VerticalStackLayout>

                        <!-- Auth Messages -->
                        <Label
                            Text="{Binding AuthError}"
                            IsVisible="{Binding HasAuthError}"
                            Style="{StaticResource ErrorText}"
                            FontSize="13"/>

                        <Label
                            Text="{Binding AuthInfo}"
                            IsVisible="{Binding HasAuthInfo}"
                            FontSize="13"
                            TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"/>

                        <!-- Loading -->
                        <HorizontalStackLayout
                            Spacing="10"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsBusy}">
                            <ActivityIndicator
                                IsRunning="{Binding IsBusy}"/>
                            <Label
                                Text="Signing in..."
                                VerticalOptions="Center"
                                Style="{StaticResource Caption}"/>
                        </HorizontalStackLayout>

                        <!-- Remember + Forgot -->
                        <Grid ColumnDefinitions="*,Auto"
                              VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="10"
                                    VerticalOptions="Center">
                                <Switch
                                    IsToggled="{Binding RememberMe}"/>
                                <Label
                                    Text="Remember me"
                                    VerticalOptions="Center"
                                    FontSize="14"
                                    TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                            </HorizontalStackLayout>

                            <Button
                                Grid.Column="1"
                                Text="Forgot password?"
                                Command="{Binding ForgotPasswordCommand}"
                                IsEnabled="{Binding IsNotBusy}"
                                Style="{StaticResource GhostButton}"
                                FontSize="14"
                                Padding="8,0"
                                HeightRequest="36"/>
                        </Grid>

                        <!-- Buttons -->
                        <Button
                            Text="Login"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource PrimaryButton}"/>

                        <Button
                            Text="Create an account"
                            Command="{Binding NavigateToRegisterCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource SecondaryButton}"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- Info Banner -->
                <Frame
                    Padding="16"
                    CornerRadius="14"
                    BackgroundColor="{AppThemeBinding Light=#E9F2FF, Dark=#0D2137}"
                    BorderColor="{AppThemeBinding Light=#C7DBFF, Dark=#1A3A5C}"
                    HasShadow="False">
                    <Label
                        Text="Demo login page for TaskNest mobile coursework project."
                        FontSize="13"
                        TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"/>
                </Frame>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>