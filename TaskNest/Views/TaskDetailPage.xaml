<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        x:Class="TaskNest.Views.TaskDetailPage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
        x:DataType="viewModels:TaskDetailViewModel"
        Title="Task Details"
        BackgroundColor="{AppThemeBinding Light=#F7F8FC, Dark=#0F172A}">

        <ScrollView>
                <VerticalStackLayout Padding="24"
                                Spacing="22">

                        <VerticalStackLayout Spacing="6">
                                <Label Text="Task Details"
                                                FontSize="32"
                                                FontAttributes="Bold"
                                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                                <Label Text="Review task information, progress, and next actions."
                                                FontSize="15"
                                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                        </VerticalStackLayout>

                        <Frame Padding="22"
                                        CornerRadius="18"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                                        BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}"
                                        HasShadow="True">
                                <VerticalStackLayout Spacing="18">
                                        <VerticalStackLayout Spacing="6">
                                                <Label Text="{Binding TaskTitle}"
                                                                FontSize="28"
                                                                FontAttributes="Bold"
                                                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>

                                                <Label Text="{Binding Category}"
                                                                FontSize="14"
                                                                TextColor="{AppThemeBinding Light=#2563EB, Dark=#60A5FA}"/>
                                        </VerticalStackLayout>

                                        <BoxView HeightRequest="1"
                                                        Color="{AppThemeBinding Light=#E5E7EB, Dark=#334155}"/>

                                        <VerticalStackLayout Spacing="8">
                                                <Label Text="Description"
                                                                FontSize="18"
                                                                FontAttributes="Bold"
                                                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                                                <Label Text="{Binding Description}"
                                                                FontSize="15"
                                                                LineBreakMode="WordWrap"
                                                                TextColor="{AppThemeBinding Light=#374151, Dark=#CBD5E1}"/>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Spacing="8">
                                                <Label Text="Reflection"
                                                                FontSize="18"
                                                                FontAttributes="Bold"
                                                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                                                <Label Text="{Binding Reflection}"
                                                                FontSize="15"
                                                                LineBreakMode="WordWrap"
                                                                TextColor="{AppThemeBinding Light=#374151, Dark=#CBD5E1}"/>
                                        </VerticalStackLayout>

                                        <Grid ColumnDefinitions="*,*"
                                                        RowDefinitions="Auto,Auto"
                                                        ColumnSpacing="18"
                                                        RowSpacing="18">
                                                <VerticalStackLayout Grid.Row="0"
                                                                Grid.Column="0"
                                                                Spacing="4">
                                                        <Label Text="Due Date"
                                                                        FontSize="14"
                                                                        FontAttributes="Bold"
                                                                        TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                                                        <Label Text="{Binding DueDate}"
                                                                        FontSize="15"
                                                                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Row="0"
                                                                Grid.Column="1"
                                                                Spacing="4">
                                                        <Label Text="Category"
                                                                        FontSize="14"
                                                                        FontAttributes="Bold"
                                                                        TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"/>
                                                        <Label Text="{Binding Category}"
                                                                        FontSize="15"
                                                                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                                                </VerticalStackLayout>

                                        </Grid>

                                        <!-- Status -->
                                        <HorizontalStackLayout Spacing="8">
                                                <Label Text="Status:"
                                                                FontSize="15"
                                                                FontAttributes="Bold"
                                                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"
                                                                VerticalOptions="Center"/>
                                                <Label Text="{Binding StatusLabel}"
                                                                FontSize="15"
                                                                TextColor="{Binding IsCompleted, Converter={StaticResource CompletedStatusColorConverter}}"
                                                                VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <Grid ColumnDefinitions="*,*,*,*"
                                                        ColumnSpacing="10">
                                                <Button Text="Back"
                                                        Command="{Binding BackCommand}"
                                                        BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}"
                                                                TextColor="{AppThemeBinding Light=#111827, Dark=#F8FAFC}"
                                                                CornerRadius="12"
                                                                HeightRequest="50"/>

                                                <Button Text="Edit"
                                                        Grid.Column="1"
                                                        Command="{Binding EditCommand}"
                                                        BackgroundColor="{AppThemeBinding Light=#2563EB, Dark=#3B82F6}"
                                                                TextColor="White"
                                                                CornerRadius="12"
                                                                HeightRequest="50"/>

                                                <Button Text="Complete"
                                                        Grid.Column="2"
                                                        Command="{Binding CompleteCommand}"
                                                        IsEnabled="{Binding IsNotCompleted}"
                                                        BackgroundColor="{AppThemeBinding Light=#D1FAE5, Dark=#064E3B}"
                                                                TextColor="{AppThemeBinding Light=#065F46, Dark=#A7F3D0}"
                                                                CornerRadius="12"
                                                                HeightRequest="50"/>

                                                <Button Text="Delete"
                                                        Grid.Column="3"
                                                        Command="{Binding DeleteCommand}"
                                                        BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#7F1D1D}"
                                                                TextColor="{AppThemeBinding Light=#B91C1C, Dark=#FECACA}"
                                                                CornerRadius="12"
                                                                HeightRequest="50"/>
                                        </Grid>
                                </VerticalStackLayout>
                        </Frame>
                </VerticalStackLayout>
        </ScrollView>
</ContentPage>