<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        x:Class="TaskNest.Views.TaskDetailPage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        Title="Task Details"
        BackgroundColor="#F7F8FC">

        <ScrollView>
                <VerticalStackLayout Padding="24"
                                Spacing="22">

                        <!-- Header -->
                        <VerticalStackLayout Spacing="6">
                                <Label
                                        Text="Task Details"
                                        FontSize="32"
                                        FontAttributes="Bold"
                                        TextColor="#111827"/>

                                <Label
                                        Text="Review task information, progress, and next actions."
                                        FontSize="15"
                                        TextColor="#6B7280"/>
                        </VerticalStackLayout>

                        <!-- Main Task Card -->
                        <Frame
                                Padding="22"
                                CornerRadius="18"
                                BackgroundColor="White"
                                HasShadow="True">

                                <VerticalStackLayout Spacing="18">

                                        <Grid ColumnDefinitions="*,Auto"
                                                        ColumnSpacing="12">
                                                <VerticalStackLayout Spacing="6">
                                                        <Label
                                                                Text="Finish UI navigation"
                                                                FontSize="28"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>

                                                        <Label
                                                                Text="Coursework / High Priority"
                                                                FontSize="14"
                                                                TextColor="#2563EB"/>
                                                </VerticalStackLayout>

                                                <Frame
                                                        Padding="12,8"
                                                        CornerRadius="16"
                                                        HasShadow="False"
                                                        BackgroundColor="#FEE2E2"
                                                        VerticalOptions="Start">
                                                        <Label
                                                                Text="High"
                                                                FontSize="12"
                                                                FontAttributes="Bold"
                                                                TextColor="#B91C1C"/>
                                                </Frame>
                                        </Grid>

                                        <BoxView HeightRequest="1"
                                                        Color="#E5E7EB"/>

                                        <!-- Description -->
                                        <VerticalStackLayout Spacing="8">
                                                <Label
                                                        Text="Description"
                                                        FontSize="18"
                                                        FontAttributes="Bold"
                                                        TextColor="#111827"/>

                                                <Label
                                                        Text="Complete the remaining navigation flow across the app and make sure every page feels visually consistent for the final coursework demonstration."
                                                        FontSize="15"
                                                        LineBreakMode="WordWrap"
                                                        TextColor="#374151"/>
                                        </VerticalStackLayout>

                                        <!-- Metadata -->
                                        <Grid ColumnDefinitions="*,*"
                                                        RowDefinitions="Auto,Auto"
                                                        ColumnSpacing="18"
                                                        RowSpacing="18">

                                                <VerticalStackLayout Grid.Row="0"
                                                                Grid.Column="0"
                                                                Spacing="4">
                                                        <Label
                                                                Text="Due Date"
                                                                FontSize="14"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                        <Label
                                                                Text="10 April 2026"
                                                                FontSize="15"
                                                                TextColor="#6B7280"/>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Row="0"
                                                                Grid.Column="1"
                                                                Spacing="4">
                                                        <Label
                                                                Text="Category"
                                                                FontSize="14"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                        <Label
                                                                Text="Coursework"
                                                                FontSize="15"
                                                                TextColor="#6B7280"/>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Row="1"
                                                                Grid.Column="0"
                                                                Spacing="4">
                                                        <Label
                                                                Text="Status"
                                                                FontSize="14"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                        <Label
                                                                Text="In Progress"
                                                                FontSize="15"
                                                                TextColor="#F59E0B"/>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Row="1"
                                                                Grid.Column="1"
                                                                Spacing="4">
                                                        <Label
                                                                Text="Assigned To"
                                                                FontSize="14"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                        <Label
                                                                Text="Parsa"
                                                                FontSize="15"
                                                                TextColor="#6B7280"/>
                                                </VerticalStackLayout>
                                        </Grid>

                                        <BoxView HeightRequest="1"
                                                        Color="#E5E7EB"/>

                                        <!-- Action Buttons -->
                                        <Grid ColumnDefinitions="*,*"
                                                        ColumnSpacing="14">
                                                <Button
                                                        Grid.Column="0"
                                                        Text="Back to Tasks"
                                                        BackgroundColor="#E5E7EB"
                                                        TextColor="#111827"
                                                        CornerRadius="12"
                                                        HeightRequest="50"/>

                                                <Button
                                                        Grid.Column="1"
                                                        Text="Edit Task"
                                                        BackgroundColor="#2563EB"
                                                        TextColor="White"
                                                        CornerRadius="12"
                                                        HeightRequest="50"
                                                        Clicked="OnEditTaskClicked"/>
                                        </Grid>

                                </VerticalStackLayout>
                        </Frame>

                        <!-- Activity / Notes Card -->
                        <Frame
                                Padding="22"
                                CornerRadius="18"
                                BackgroundColor="White"
                                HasShadow="True">

                                <VerticalStackLayout Spacing="14">
                                        <Label
                                                Text="Recent Notes"
                                                FontSize="20"
                                                FontAttributes="Bold"
                                                TextColor="#111827"/>

                                        <Frame
                                                Padding="14"
                                                CornerRadius="14"
                                                HasShadow="False"
                                                BackgroundColor="#F9FAFB">
                                                <VerticalStackLayout Spacing="4">
                                                        <Label
                                                                Text="UI review completed"
                                                                FontSize="15"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                        <Label
                                                                Text="Checked layout consistency between Dashboard, Tasks, and Task Edit screens."
                                                                FontSize="14"
                                                                TextColor="#6B7280"/>
                                                </VerticalStackLayout>
                                        </Frame>

                                        <Frame
                                                Padding="14"
                                                CornerRadius="14"
                                                HasShadow="False"
                                                BackgroundColor="#F9FAFB">
                                                <VerticalStackLayout Spacing="4">
                                                        <Label
                                                                Text="Next step"
                                                                FontSize="15"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                        <Label
                                                                Text="Complete Task Detail screen and finish the remaining Epic 2 polish tasks."
                                                                FontSize="14"
                                                                TextColor="#6B7280"/>
                                                </VerticalStackLayout>
                                        </Frame>
                                </VerticalStackLayout>
                        </Frame>

                </VerticalStackLayout>
        </ScrollView>
</ContentPage>