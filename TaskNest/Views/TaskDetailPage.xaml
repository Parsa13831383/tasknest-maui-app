<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        x:Class="TaskNest.Views.TaskDetailPage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        Title="Task Details"
        BackgroundColor="#F7F8FC">

        <ScrollView>
                <VerticalStackLayout Padding="24"
                                Spacing="22">

                        <VerticalStackLayout Spacing="6">
                                <Label Text="Task Details"
                                                FontSize="32"
                                                FontAttributes="Bold"
                                                TextColor="#111827"/>
                                <Label Text="Review task information, progress, and next actions."
                                                FontSize="15"
                                                TextColor="#6B7280"/>
                        </VerticalStackLayout>

                        <Frame Padding="22"
                                        CornerRadius="18"
                                        BackgroundColor="White"
                                        HasShadow="True">
                                <VerticalStackLayout Spacing="18">
                                        <Grid ColumnDefinitions="*,Auto"
                                                        ColumnSpacing="12">
                                                <VerticalStackLayout Spacing="6">
                                                        <Label Text="{Binding TaskTitle}"
                                                                        FontSize="28"
                                                                        FontAttributes="Bold"
                                                                        TextColor="#111827"/>

                                                        <Label Text="{Binding Category}"
                                                                        FontSize="14"
                                                                        TextColor="#2563EB"/>
                                                </VerticalStackLayout>

                                                <Frame Padding="12,8"
                                                                CornerRadius="16"
                                                                HasShadow="False"
                                                                BackgroundColor="#FEE2E2"
                                                                VerticalOptions="Start">
                                                        <Label Text="{Binding PriorityText}"
                                                                        FontSize="12"
                                                                        FontAttributes="Bold"
                                                                        TextColor="#B91C1C"/>
                                                </Frame>
                                        </Grid>

                                        <BoxView HeightRequest="1"
                                                        Color="#E5E7EB"/>

                                        <VerticalStackLayout Spacing="8">
                                                <Label Text="Description"
                                                                FontSize="18"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                <Label Text="{Binding Description}"
                                                                FontSize="15"
                                                                LineBreakMode="WordWrap"
                                                                TextColor="#374151"/>
                                        </VerticalStackLayout>

                                        <Grid ColumnDefinitions="*,*"
                                                        RowDefinitions="Auto,Auto"
                                                        ColumnSpacing="18"
                                                        RowSpacing="18">
                                                <VerticalStackLayout Grid.Row="0"
                                                                Grid.Column="0"
                                                                Spacing="4">
                                                        <Label Text="Due Date"
                                                                        FontSize="14"
                                                                        FontAttributes="Bold"
                                                                        TextColor="#111827"/>
                                                        <Label Text="{Binding DueDate}"
                                                                        FontSize="15"
                                                                        TextColor="#6B7280"/>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Row="0"
                                                                Grid.Column="1"
                                                                Spacing="4">
                                                        <Label Text="Category"
                                                                        FontSize="14"
                                                                        FontAttributes="Bold"
                                                                        TextColor="#111827"/>
                                                        <Label Text="{Binding Category}"
                                                                        FontSize="15"
                                                                        TextColor="#6B7280"/>
                                                </VerticalStackLayout>

                                        </Grid>

                                        <BoxView HeightRequest="1"
                                                        Color="#E5E7EB"/>

                                        <Button
                                                Text="Toggle Completion"
                                                Command="{Binding ToggleCompleteCommand}"
                                                BackgroundColor="#ECFDF5"
                                                TextColor="#065F46"
                                                CornerRadius="12"
                                                HeightRequest="44"/>

                                        <Grid ColumnDefinitions="*,*,*"
                                                        ColumnSpacing="14">
                                                <Button Text="Back to Tasks"
                                                        Command="{Binding BackCommand}"
                                                        BackgroundColor="#E5E7EB"
                                                                TextColor="#111827"
                                                                CornerRadius="12"
                                                                HeightRequest="50"/>

                                                <Button Text="Edit Task"
                                                        Grid.Column="1"
                                                        Command="{Binding EditCommand}"
                                                        BackgroundColor="#2563EB"
                                                                TextColor="White"
                                                                CornerRadius="12"
                                                                HeightRequest="50"/>

                                                <Button Text="Delete"
                                                        Grid.Column="2"
                                                        Command="{Binding DeleteCommand}"
                                                        BackgroundColor="#FEE2E2"
                                                                TextColor="#B91C1C"
                                                                CornerRadius="12"
                                                                HeightRequest="50"/>
                                        </Grid>
                                </VerticalStackLayout>
                        </Frame>
                </VerticalStackLayout>
        </ScrollView>
</ContentPage>