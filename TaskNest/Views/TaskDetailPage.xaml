<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        x:Class="TaskNest.Views.TaskDetailPage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
        x:DataType="viewModels:TaskDetailViewModel"
        Title="Task Details"
        BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

        <ScrollView>
                <VerticalStackLayout Padding="20,32,20,24"
                                Spacing="20">

                        <!-- Header -->
                        <VerticalStackLayout Spacing="6">
                                <Label Text="Task Details"
                                                Style="{StaticResource PageTitle}"/>
                                <Label Text="Review task information, progress, and next actions."
                                                Style="{StaticResource PageSubtitle}"/>
                        </VerticalStackLayout>

                        <!-- Task Detail Card -->
                        <Frame Padding="20"
                                        CornerRadius="16"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                                        BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                                        HasShadow="False">
                                <VerticalStackLayout Spacing="18">

                                        <!-- Title & Category -->
                                        <VerticalStackLayout Spacing="6">
                                                <Label Text="{Binding TaskTitle}"
                                                                FontSize="26"
                                                                FontFamily="OpenSansSemibold"
                                                                TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                                                <Label Text="{Binding Category}"
                                                                FontSize="14"
                                                                TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"/>
                                        </VerticalStackLayout>

                                        <BoxView HeightRequest="1"
                                                        Color="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"/>

                                        <!-- Description -->
                                        <VerticalStackLayout Spacing="8">
                                                <Label Text="Description"
                                                                Style="{StaticResource SectionTitle}"
                                                                FontSize="17"/>
                                                <Label Text="{Binding Description}"
                                                                Style="{StaticResource Body}"
                                                                LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>

                                        <!-- Reflection -->
                                        <VerticalStackLayout Spacing="8">
                                                <Label Text="Reflection"
                                                                Style="{StaticResource SectionTitle}"
                                                                FontSize="17"/>
                                                <Label Text="{Binding Reflection}"
                                                                Style="{StaticResource Body}"
                                                                LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>

                                        <!-- Due Date & Category Grid -->
                                        <Grid ColumnDefinitions="*,*"
                                                        ColumnSpacing="16">
                                                <VerticalStackLayout Spacing="4">
                                                        <Label Text="Due Date"
                                                                        Style="{StaticResource FieldLabel}"/>
                                                        <Label Text="{Binding DueDate}"
                                                                        Style="{StaticResource Body}"/>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Column="1"
                                                                Spacing="4">
                                                        <Label Text="Category"
                                                                        Style="{StaticResource FieldLabel}"/>
                                                        <Label Text="{Binding Category}"
                                                                        Style="{StaticResource Body}"/>
                                                </VerticalStackLayout>
                                        </Grid>

                                        <!-- Status -->
                                        <HorizontalStackLayout Spacing="8">
                                                <Label Text="Status:"
                                                                FontSize="15"
                                                                FontFamily="OpenSansSemibold"
                                                                TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"
                                                                VerticalOptions="Center"/>
                                                <Label Text="{Binding StatusLabel}"
                                                                FontSize="15"
                                                                TextColor="{Binding IsCompleted, Converter={StaticResource CompletedStatusColorConverter}}"
                                                                VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <!-- Action Buttons -->
                                        <Grid ColumnDefinitions="*,*"
                                                        RowDefinitions="Auto,Auto"
                                                        ColumnSpacing="10"
                                                        RowSpacing="10">
                                                <Button Text="Back"
                                                                Command="{Binding BackCommand}"
                                                                Style="{StaticResource SecondaryButton}"/>

                                                <Button Text="Edit"
                                                                Grid.Column="1"
                                                                Command="{Binding EditCommand}"
                                                                Style="{StaticResource PrimaryButton}"/>

                                                <Button Text="Complete"
                                                                Grid.Row="1"
                                                                Command="{Binding CompleteCommand}"
                                                                IsEnabled="{Binding IsNotCompleted}"
                                                                BackgroundColor="{AppThemeBinding Light=#E8FAF0, Dark=#0D3B1F}"
                                                                TextColor="{AppThemeBinding Light=#166534, Dark=#A7F3D0}"
                                                                CornerRadius="12"
                                                                HeightRequest="48"/>

                                                <Button Text="Delete"
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                Command="{Binding DeleteCommand}"
                                                                Style="{StaticResource DestructiveButton}"/>
                                        </Grid>
                                </VerticalStackLayout>
                        </Frame>
                </VerticalStackLayout>
        </ScrollView>
</ContentPage>