<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        x:Class="TaskNest.Views.TaskEditPage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        Title="Edit Task"
        BackgroundColor="#F7F8FC">

        <ScrollView>
                <VerticalStackLayout Padding="24"
                                                         Spacing="24">

                        <VerticalStackLayout Spacing="8">
                                <Label
                                        Text="Edit Task"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="32"
                                        TextColor="#111827"/>

                                <Label
                                        Text="Update your task details and manage completion."
                                        FontFamily="OpenSansRegular"
                                        FontSize="15"
                                        TextColor="#6B7280"
                                        Opacity="0.82"/>
                        </VerticalStackLayout>

                        <Border
                                Padding="20"
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18">
                                <Border.Shadow>
                                        <Shadow Brush="#14000000"
                                                        Offset="0,10"
                                                        Radius="18"
                                                        Opacity="0.08"/>
                                </Border.Shadow>

                                <VerticalStackLayout Spacing="20">
                                        <Grid ColumnDefinitions="*,Auto"
                                                  VerticalOptions="Center">
                                                <VerticalStackLayout Spacing="6">
                                                        <Label
                                                                Text="Task Details"
                                                                FontFamily="OpenSansSemibold"
                                                                FontSize="19"
                                                                TextColor="#111827"/>

                                                        <Label
                                                                Text="Refine the content, priority, and completion state."
                                                                FontFamily="OpenSansRegular"
                                                                FontSize="13"
                                                                TextColor="#6B7280"
                                                                Opacity="0.8"/>
                                                </VerticalStackLayout>

                                                <Border
                                                        Grid.Column="1"
                                                        Padding="12,6"
                                                        BackgroundColor="#EEF2FF"
                                                        Stroke="#C7D2FE"
                                                        StrokeThickness="1"
                                                        StrokeShape="RoundRectangle 999">
                                                        <Label
                                                                Text="High"
                                                                FontFamily="OpenSansSemibold"
                                                                FontSize="12"
                                                                TextColor="#4338CA"
                                                                VerticalOptions="Center"/>
                                                </Border>
                                        </Grid>

                                        <BoxView HeightRequest="1"
                                                         Color="#E5E7EB"/>

                                        <VerticalStackLayout Spacing="16">
                                                <VerticalStackLayout Spacing="8">
                                                        <Label
                                                                Text="Task Title"
                                                                FontFamily="OpenSansSemibold"
                                                                FontSize="14"
                                                                TextColor="#111827"/>

                                                        <Entry
                                                                x:Name="TaskTitleEntry"
                                                                Placeholder="Refine dashboard task editor"
                                                                BackgroundColor="#F9FAFB"
                                                                TextColor="#111827"
                                                                PlaceholderColor="#9CA3AF"
                                                                HeightRequest="52"
                                                                Margin="0"
                                                                Text="Edit Task screen polish"/>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Spacing="8">
                                                        <Label
                                                                Text="Description"
                                                                FontFamily="OpenSansSemibold"
                                                                FontSize="14"
                                                                TextColor="#111827"/>

                                                        <Editor
                                                                x:Name="DescriptionEditor"
                                                                Placeholder="Add a concise task description, context, or acceptance notes."
                                                                AutoSize="TextChanges"
                                                                BackgroundColor="#F9FAFB"
                                                                TextColor="#111827"
                                                                PlaceholderColor="#9CA3AF"
                                                                HeightRequest="110"
                                                                Margin="0"
                                                                Text="Polish the task edit page with stronger spacing, hierarchy, and clear actions for grading."/>
                                                </VerticalStackLayout>

                                                <Grid ColumnDefinitions="*,*"
                                                          ColumnSpacing="12">
                                                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                                                                <Label
                                                                        Text="Category"
                                                                        FontFamily="OpenSansSemibold"
                                                                        FontSize="14"
                                                                        TextColor="#111827"/>

                                                                <Picker
                                                                        x:Name="CategoryPicker"
                                                                        Title="Select category"
                                                                        BackgroundColor="#F9FAFB"
                                                                        TextColor="#111827"
                                                                        TitleColor="#6B7280"/>
                                                        </VerticalStackLayout>

                                                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                                                                <Label
                                                                        Text="Priority"
                                                                        FontFamily="OpenSansSemibold"
                                                                        FontSize="14"
                                                                        TextColor="#111827"/>

                                                                <Picker
                                                                        x:Name="PriorityPicker"
                                                                        Title="Select priority"
                                                                        BackgroundColor="#F9FAFB"
                                                                        TextColor="#111827"
                                                                        TitleColor="#6B7280"/>
                                                        </VerticalStackLayout>
                                                </Grid>

                                                <Grid ColumnDefinitions="*,Auto"
                                                          ColumnSpacing="12"
                                                          VerticalOptions="Center">
                                                        <VerticalStackLayout Spacing="8">
                                                                <Label
                                                                        Text="Due Date"
                                                                        FontFamily="OpenSansSemibold"
                                                                        FontSize="14"
                                                                        TextColor="#111827"/>

                                                                <DatePicker
                                                                        x:Name="DueDatePicker"
                                                                        BackgroundColor="#F9FAFB"
                                                                        TextColor="#111827"
                                                                        Format="ddd, MMM d, yyyy"/>
                                                        </VerticalStackLayout>

                                                        <VerticalStackLayout Grid.Column="1"
                                                                                                 Spacing="8"
                                                                                                 HorizontalOptions="End">
                                                                <Label
                                                                        Text="Completed"
                                                                        FontFamily="OpenSansSemibold"
                                                                        FontSize="14"
                                                                        TextColor="#111827"
                                                                        HorizontalTextAlignment="End"/>

                                                                <Grid ColumnDefinitions="Auto,Auto"
                                                                          ColumnSpacing="10"
                                                                          HorizontalOptions="End"
                                                                          VerticalOptions="Center">
                                                                        <Label
                                                                                Grid.Column="0"
                                                                                Text="Mark as completed"
                                                                                FontFamily="OpenSansRegular"
                                                                                FontSize="13"
                                                                                TextColor="#6B7280"
                                                                                VerticalOptions="Center"/>

                                                                        <Switch
                                                                                x:Name="CompletedSwitch"
                                                                                Grid.Column="1"
                                                                                OnColor="#2563EB"
                                                                                ThumbColor="White"
                                                                                HorizontalOptions="End"
                                                                                VerticalOptions="Center"/>
                                                                </Grid>
                                                        </VerticalStackLayout>
                                                </Grid>
                                        </VerticalStackLayout>

                                        <BoxView HeightRequest="1"
                                                         Color="#E5E7EB"/>

                                        <Grid ColumnDefinitions="*,*"
                                                  ColumnSpacing="12">
                                                <Button
                                                        Text="Cancel"
                                                        BackgroundColor="#EEF2F7"
                                                        TextColor="#111827"
                                                        FontFamily="OpenSansSemibold"
                                                        CornerRadius="16"
                                                        HeightRequest="52"/>

                                                <Button
                                                        Grid.Column="1"
                                                        Text="Save Changes"
                                                        BackgroundColor="#2563EB"
                                                        TextColor="White"
                                                        FontFamily="OpenSansSemibold"
                                                        CornerRadius="16"
                                                        HeightRequest="52"/>
                                        </Grid>
                                </VerticalStackLayout>
                        </Border>

                        <Border
                                Padding="16"
                                BackgroundColor="#FFF5F5"
                                Stroke="#FECACA"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16">
                                <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="12"
                                          VerticalOptions="Center">
                                        <VerticalStackLayout Spacing="4">
                                                <Label
                                                        Text="Danger zone"
                                                        FontFamily="OpenSansSemibold"
                                                        FontSize="14"
                                                        TextColor="#B91C1C"/>

                                                <Label
                                                        Text="Deleting this task will remove it from the dashboard and task list."
                                                        FontFamily="OpenSansRegular"
                                                        FontSize="13"
                                                        TextColor="#991B1B"
                                                        Opacity="0.82"/>
                                        </VerticalStackLayout>

                                        <Button
                                                Grid.Column="1"
                                                Text="Delete Task"
                                                BackgroundColor="#FEF2F2"
                                                TextColor="#B91C1C"
                                                FontFamily="OpenSansSemibold"
                                                CornerRadius="14"
                                                HeightRequest="46"
                                                BorderColor="#FCA5A5"
                                                BorderWidth="1"/>
                                </Grid>
                        </Border>

                </VerticalStackLayout>
        </ScrollView>
</ContentPage>