<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        x:Class="TaskNest.Views.TaskEditPage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
        x:DataType="viewModels:TaskEditViewModel"
        Title="Edit Task"
        BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

        <ScrollView>
                <VerticalStackLayout Padding="20,32,20,24"
                                Spacing="20">

                        <!-- Header -->
                        <VerticalStackLayout Spacing="6">
                                <Label
                                        Text="Edit Task"
                                        Style="{StaticResource PageTitle}"/>
                                <Label
                                        Text="Update task details, deadline, and progress."
                                        Style="{StaticResource PageSubtitle}"/>
                        </VerticalStackLayout>

                        <!-- Form Card -->
                        <Frame
                                Padding="20"
                                CornerRadius="16"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                                HasShadow="False">

                                <VerticalStackLayout Spacing="18">

                                        <Label
                                                Text="Task Information"
                                                Style="{StaticResource SectionTitle}"/>

                                        <!-- Title -->
                                        <VerticalStackLayout Spacing="6">
                                                <Label
                                                        Text="Task Title"
                                                        Style="{StaticResource FieldLabel}"/>
                                                <Entry
                                                        Text="{Binding TaskTitle}"
                                                        Placeholder="Enter task title"/>
                                        </VerticalStackLayout>

                                        <!-- Description -->
                                        <VerticalStackLayout Spacing="6">
                                                <Label
                                                        Text="Description"
                                                        Style="{StaticResource FieldLabel}"/>
                                                <Editor
                                                        Text="{Binding Description}"
                                                        Placeholder="Enter task description"
                                                        AutoSize="TextChanges"
                                                        HeightRequest="120"/>
                                        </VerticalStackLayout>

                                        <Label
                                                Text="Status &amp; Deadline"
                                                Style="{StaticResource SectionTitle}"
                                                FontSize="17"/>

                                        <!-- Category -->
                                        <VerticalStackLayout Spacing="6">
                                                <Label
                                                        Text="Category"
                                                        Style="{StaticResource FieldLabel}"/>
                                                <Picker
                                                        ItemsSource="{Binding CategoryNames}"
                                                        SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                                        Title="Select a category"/>
                                                <Entry
                                                        Text="{Binding SelectedCategory, Mode=TwoWay}"
                                                        Placeholder="Or type a new category"/>
                                        </VerticalStackLayout>

                                        <!-- Task Color -->
                                        <VerticalStackLayout Spacing="6">
                                                <Label
                                                        Text="Task Color"
                                                        Style="{StaticResource FieldLabel}"/>

                                                <CollectionView
                                                        ItemsSource="{Binding AvailableTaskColors}"
                                                        SelectionMode="None"
                                                        HeightRequest="42">
                                                        <CollectionView.ItemsLayout>
                                                                <LinearItemsLayout Orientation="Horizontal"
                                                                        ItemSpacing="10"/>
                                                        </CollectionView.ItemsLayout>

                                                        <CollectionView.ItemTemplate>
                                                                <DataTemplate x:DataType="viewModels:TaskColorOption">
                                                                        <Border
                                                                                WidthRequest="32"
                                                                                HeightRequest="32"
                                                                                StrokeShape="RoundRectangle 16"
                                                                                BackgroundColor="{Binding Color}"
                                                                                Stroke="{AppThemeBinding Light=#E5E5EA, Dark=#48484A}"
                                                                                StrokeThickness="1">
                                                                                <Border.Triggers>
                                                                                        <DataTrigger TargetType="Border"
                                                                                                Binding="{Binding IsSelected}"
                                                                                                Value="True">
                                                                                                <Setter Property="Stroke"
                                                                                                        Value="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                                                                                                <Setter Property="StrokeThickness"
                                                                                                        Value="2.5"/>
                                                                                        </DataTrigger>
                                                                                </Border.Triggers>
                                                                                <Border.GestureRecognizers>
                                                                                        <TapGestureRecognizer
                                                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectTaskColorCommand}"
                                                                                                CommandParameter="{Binding .}"/>
                                                                                </Border.GestureRecognizers>

                                                                                <Label
                                                                                        Text="✓"
                                                                                        FontSize="14"
                                                                                        HorizontalOptions="Center"
                                                                                        VerticalOptions="Center"
                                                                                        TextColor="White"
                                                                                        IsVisible="{Binding IsSelected}"/>
                                                                        </Border>
                                                                </DataTemplate>
                                                        </CollectionView.ItemTemplate>
                                                </CollectionView>
                                        </VerticalStackLayout>

                                        <!-- Due Date -->
                                        <Frame
                                                Padding="14"
                                                CornerRadius="12"
                                                HasShadow="False"
                                                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                                                BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}">
                                                <Grid ColumnDefinitions="Auto,*"
                                                        ColumnSpacing="12">
                                                        <Label
                                                                Text="●"
                                                                FontSize="18"
                                                                TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"
                                                                VerticalOptions="Center"/>

                                                        <VerticalStackLayout Grid.Column="1"
                                                                Spacing="6">
                                                                <Label
                                                                        Text="Due Date"
                                                                        Style="{StaticResource Caption}"/>
                                                                <DatePicker
                                                                        Date="{Binding DueDate}"
                                                                        Format="ddd, dd MMM yyyy"
                                                                        TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"
                                                                        BackgroundColor="Transparent"/>
                                                        </VerticalStackLayout>
                                                </Grid>
                                        </Frame>

                                        <!-- Reflection -->
                                        <VerticalStackLayout Spacing="6">
                                                <VerticalStackLayout Spacing="4">
                                                        <Label
                                                                Text="Task Reflection"
                                                                FontSize="16"
                                                                FontFamily="OpenSansSemibold"
                                                                TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                                                        <Label
                                                                Text="Write quick notes about progress, blockers, or what you learned."
                                                                Style="{StaticResource Caption}"/>
                                                </VerticalStackLayout>

                                                <Editor
                                                        Text="{Binding Reflection}"
                                                        Placeholder="Add your reflection here..."
                                                        AutoSize="TextChanges"
                                                        HeightRequest="110"/>
                                        </VerticalStackLayout>

                                        <!-- Action Buttons -->
                                        <Grid ColumnDefinitions="*,*"
                                                        ColumnSpacing="10">
                                                <Button
                                                        Grid.Column="0"
                                                        Text="Cancel"
                                                        Command="{Binding CancelCommand}"
                                                        Style="{StaticResource SecondaryButton}"/>

                                                <Button
                                                        Grid.Column="1"
                                                        Text="Save Changes"
                                                        Command="{Binding SaveCommand}"
                                                        Style="{StaticResource PrimaryButton}"/>
                                        </Grid>

                                </VerticalStackLayout>
                        </Frame>

                </VerticalStackLayout>
        </ScrollView>
</ContentPage>