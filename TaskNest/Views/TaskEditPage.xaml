<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        x:Class="TaskNest.Views.TaskEditPage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
        x:DataType="viewModels:TaskEditViewModel"
        Title="Edit Task"
        BackgroundColor="#F7F8FC">

        <ScrollView>
                <VerticalStackLayout Padding="24"
                                Spacing="22">

                        <VerticalStackLayout Spacing="6">
                                <Label
                                        Text="Edit Task"
                                        FontSize="32"
                                        FontAttributes="Bold"
                                        TextColor="#111827"/>

                                <Label
                                        Text="Update task details, deadline, and progress."
                                        FontSize="15"
                                        TextColor="#6B7280"/>
                        </VerticalStackLayout>

                        <Frame
                                Padding="22"
                                CornerRadius="18"
                                BackgroundColor="White"
                                HasShadow="True">

                                <VerticalStackLayout Spacing="18">

                                        <Grid ColumnDefinitions="*,Auto"
                                                        ColumnSpacing="12">
                                                <Label
                                                        Text="Task Information"
                                                        FontSize="20"
                                                        FontAttributes="Bold"
                                                        TextColor="#111827"/>

                                                <Frame
                                                        Padding="10,6"
                                                        CornerRadius="14"
                                                        HasShadow="False"
                                                        BackgroundColor="#FEE2E2"
                                                        VerticalOptions="Start">
                                                        <Label
                                                                Text="{Binding SelectedPriority}"
                                                                FontSize="12"
                                                                FontAttributes="Bold"
                                                                TextColor="#B91C1C"/>
                                                </Frame>
                                        </Grid>

                                        <VerticalStackLayout Spacing="8">
                                                <Label
                                                        Text="Task Title"
                                                        FontSize="15"
                                                        FontAttributes="Bold"
                                                        TextColor="#111827"/>
                                                <Entry
                                                        Text="{Binding TaskTitle}"
                                                        Placeholder="Enter task title"
                                                        BackgroundColor="#F9FAFB"
                                                        TextColor="#111827"/>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Spacing="8">
                                                <Label
                                                        Text="Description"
                                                        FontSize="15"
                                                        FontAttributes="Bold"
                                                        TextColor="#111827"/>
                                                <Editor
                                                        Text="{Binding Description}"
                                                        Placeholder="Enter task description"
                                                        AutoSize="TextChanges"
                                                        HeightRequest="120"
                                                        BackgroundColor="#F9FAFB"
                                                        TextColor="#111827"/>
                                        </VerticalStackLayout>

                                        <Label
                                                Text="Status &amp; Deadline"
                                                FontSize="18"
                                                FontAttributes="Bold"
                                                TextColor="#111827"/>

                                        <Grid ColumnDefinitions="*,*"
                                                        ColumnSpacing="12">
                                                <VerticalStackLayout Spacing="8">
                                                        <Label
                                                                Text="Category"
                                                                FontSize="15"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                        <Picker
                                                                Title="Select category"
                                                                ItemsSource="{Binding Categories}"
                                                                SelectedItem="{Binding SelectedCategory}"/>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Column="1"
                                                                Spacing="8">
                                                        <Label
                                                                Text="Priority"
                                                                FontSize="15"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                        <Picker
                                                                Title="Select priority"
                                                                ItemsSource="{Binding Priorities}"
                                                                SelectedItem="{Binding SelectedPriority}"/>
                                                </VerticalStackLayout>
                                        </Grid>

                                        <VerticalStackLayout Spacing="8">
                                                <Label
                                                        Text="Due Date"
                                                        FontSize="15"
                                                        FontAttributes="Bold"
                                                        TextColor="#111827"/>
                                                <DatePicker
                                                        Date="{Binding DueDate}"/>
                                        </VerticalStackLayout>

                                        <Grid ColumnDefinitions="*,Auto"
                                                        ColumnSpacing="12">
                                                <VerticalStackLayout Spacing="4">
                                                        <Label
                                                                Text="Mark as Completed"
                                                                FontSize="16"
                                                                FontAttributes="Bold"
                                                                TextColor="#111827"/>
                                                        <Label
                                                                Text="Toggle task completion status."
                                                                FontSize="14"
                                                                TextColor="#6B7280"/>
                                                </VerticalStackLayout>

                                                <Switch
                                                        Grid.Column="1"
                                                        IsToggled="{Binding IsCompleted}"
                                                        OnColor="#2563EB"
                                                        VerticalOptions="Center"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,*"
                                                        ColumnSpacing="14">
                                                <Button
                                                        Grid.Column="0"
                                                        Text="Cancel"
                                                        Command="{Binding CancelCommand}"
                                                        BackgroundColor="#E5E7EB"
                                                        TextColor="#111827"
                                                        CornerRadius="12"
                                                        HeightRequest="50"/>

                                                <Button
                                                        Grid.Column="1"
                                                        Text="Save Changes"
                                                        Command="{Binding SaveCommand}"
                                                        BackgroundColor="#2563EB"
                                                        TextColor="White"
                                                        CornerRadius="12"
                                                        HeightRequest="50"/>
                                        </Grid>

                                </VerticalStackLayout>
                        </Frame>

                </VerticalStackLayout>
        </ScrollView>
</ContentPage>