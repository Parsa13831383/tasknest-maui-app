<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.CategoriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:CategoriesViewModel"
    Title="Categories"
    BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="22">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Categories"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="#111827"/>

                <Label
                    Text="Organise your tasks into clear areas of focus."
                    FontSize="15"
                    TextColor="#6B7280"/>
            </VerticalStackLayout>

            <!-- Action Row -->
            <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    Text="+ Add Category"
                    Command="{Binding AddCategoryCommand}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="48"/>

                <Button
                    Grid.Column="1"
                    Text="Manage Categories"
                    Command="{Binding ManageCategoriesCommand}"
                    BackgroundColor="#E5E7EB"
                    TextColor="#111827"
                    CornerRadius="12"
                    HeightRequest="48"/>
            </Grid>

            <!-- Summary Card -->
            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="White"
                HasShadow="True">
                <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Total Categories"
                            FontSize="14"
                            TextColor="#6B7280"/>
                        <Label
                            Text="{Binding TotalCategories}"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="#111827"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1"
                            Spacing="4">
                        <Label
                            Text="Most Active"
                            FontSize="14"
                            TextColor="#6B7280"/>
                        <Label
                            Text="{Binding MostActiveCategory}"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#2563EB"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2"
                            Spacing="4">
                        <Label
                            Text="Tasks Assigned"
                            FontSize="14"
                            TextColor="#6B7280"/>
                        <Label
                            Text="{Binding TasksAssigned}"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="#10B981"/>
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- Category List -->
            <VerticalStackLayout Spacing="14">
                <Label
                    Text="Your Categories"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="#111827"/>

                <CollectionView
                    ItemsSource="{Binding Categories}"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:CategoryItem">
                            <Frame
                                Padding="18"
                                Margin="0,0,0,14"
                                CornerRadius="18"
                                BackgroundColor="White"
                                HasShadow="True">
                                <Grid ColumnDefinitions="*,Auto"
                                        ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="6">
                                        <Label
                                            Text="{Binding Name}"
                                            FontSize="20"
                                            FontAttributes="Bold"
                                            TextColor="#111827"/>
                                        <Label
                                            Text="{Binding Description}"
                                            FontSize="14"
                                            TextColor="#6B7280"/>
                                    </VerticalStackLayout>

                                    <Frame
                                        Padding="10,6"
                                        CornerRadius="14"
                                        HasShadow="False"
                                        BackgroundColor="{Binding BadgeBackgroundColor}"
                                        VerticalOptions="Start">
                                        <Label
                                            Text="{Binding TaskCountText}"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{Binding BadgeTextColor}"/>
                                    </Frame>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>