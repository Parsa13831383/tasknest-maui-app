<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.CategoriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:TaskNest.Models"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:CategoriesViewModel"
    Title="Categories"
    BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#000000}">

    <ScrollView>
        <VerticalStackLayout Padding="20,32,20,24"
                Spacing="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Categories"
                    Style="{StaticResource PageTitle}"/>

                <Label
                    Text="Organise your tasks into clear areas of focus."
                    Style="{StaticResource PageSubtitle}"/>
            </VerticalStackLayout>

            <!-- New Category Form Card -->
            <Frame
                Padding="20"
                CornerRadius="16"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                BorderColor="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                HasShadow="False">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Text="Create Category"
                        Style="{StaticResource SectionTitle}"
                        FontSize="18"/>

                    <Entry
                        Text="{Binding NewCategoryName, Mode=TwoWay}"
                        Placeholder="Category name"/>

                    <Entry
                        Text="{Binding NewCategoryDescription, Mode=TwoWay}"
                        Placeholder="Description (optional)"/>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button
                            Grid.Column="0"
                            Text="+ Add Category"
                            Command="{Binding AddCategoryCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HeightRequest="46"/>

                        <Button
                            Grid.Column="1"
                            Text="Refresh"
                            Command="{Binding ManageCategoriesCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HeightRequest="46"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Compact Stats Bar -->
            <Border
                Padding="14,12"
                Stroke="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                StrokeShape="RoundRectangle 14">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="10"
                      VerticalOptions="Center">
                    <Label Text="Total"
                           Style="{StaticResource Caption}"/>
                    <Label Grid.Column="1"
                           Text="{Binding TotalCategories}"
                           FontSize="14"
                           FontFamily="OpenSansSemibold"
                           TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>

                    <Label Grid.Column="2"
                           Text="·"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#AEAEB2, Dark=#636366}"/>

                    <Label Grid.Column="3"
                           Text="Most Active"
                           Style="{StaticResource Caption}"/>
                    <Label Grid.Column="4"
                           Text="{Binding MostActiveCategory}"
                           FontSize="14"
                           FontFamily="OpenSansSemibold"
                           TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"/>

                    <Label Grid.Column="5"
                           Text="Tasks"
                           Style="{StaticResource Caption}"/>

                    <Label Grid.Column="6"
                           Text="{Binding TasksAssigned}"
                           FontSize="14"
                           FontFamily="OpenSansSemibold"
                           TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                </Grid>
            </Border>

            <!-- Category Hub -->
            <VerticalStackLayout Spacing="14">
                <Label
                    Text="Areas of Focus"
                    Style="{StaticResource SectionTitle}"/>

                <CollectionView
                    ItemsSource="{Binding Categories}"
                    SelectionMode="None">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Padding="32,48"
                            Spacing="10">
                            <Label
                                Text="No categories yet"
                                FontSize="18"
                                FontFamily="OpenSansSemibold"
                                HorizontalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light=#8E8E93, Dark=#98989D}"/>
                            <Label
                                Text="Create your first category above to organise tasks."
                                Style="{StaticResource Caption}"
                                HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                Span="{OnPlatform MacCatalyst=3, Default=2}"
                                HorizontalItemSpacing="12"
                                VerticalItemSpacing="12"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CategoryItem">
                            <Border
                                Padding="14"
                                Stroke="{AppThemeBinding Light=#E5E5EA, Dark=#38383A}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                                StrokeShape="RoundRectangle 16">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnCategoryCardTapped"/>
                                    <PointerGestureRecognizer
                                        PointerEntered="OnCategoryCardPointerEntered"
                                        PointerExited="OnCategoryCardPointerExited"/>
                                </Border.GestureRecognizers>

                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                            Binding="{Binding IsEmptyState}"
                                            Value="True">
                                        <Setter Property="Stroke"
                                                Value="{AppThemeBinding Light=#D1D1D6, Dark=#48484A}"/>
                                        <Setter Property="StrokeDashArray"
                                                Value="5,4"/>
                                        <Setter Property="Opacity"
                                                Value="0.9"/>
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="6,*">
                                    <BoxView
                                        Grid.RowSpan="3"
                                        Grid.Column="0"
                                        CornerRadius="3"
                                        Color="{Binding AccentColor}"/>

                                    <Grid Grid.Column="1"
                                          ColumnDefinitions="Auto,*"
                                          ColumnSpacing="8"
                                          Padding="10,0,0,0">
                                        <Label
                                            Text="{Binding IconGlyph}"
                                            FontSize="17"
                                            VerticalOptions="Center"
                                            TextColor="{Binding AccentColor}"/>

                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label
                                                Text="{Binding Name}"
                                                FontSize="16"
                                                FontFamily="OpenSansSemibold"
                                                TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"/>
                                            <Label
                                                Text="{Binding Description}"
                                                FontSize="12"
                                                MaxLines="1"
                                                LineBreakMode="TailTruncation"
                                                TextColor="{AppThemeBinding Light=#8E8E93, Dark=#98989D}"/>
                                        </VerticalStackLayout>
                                    </Grid>

                                    <VerticalStackLayout Grid.Row="1"
                                            Grid.Column="1"
                                            Spacing="6"
                                            Padding="10,10,0,0">
                                        <ProgressBar
                                            Progress="{Binding ProgressValue}"
                                            ProgressColor="{Binding AccentColor}"
                                            BackgroundColor="{AppThemeBinding Light=#E5E5EA, Dark=#48484A}"
                                            HeightRequest="5"/>
                                        <Label
                                            Text="{Binding ProgressText}"
                                            FontSize="11"
                                            FontAttributes="Italic"
                                            TextColor="{AppThemeBinding Light=#8E8E93, Dark=#98989D}"/>
                                    </VerticalStackLayout>

                                    <Grid Grid.RowSpan="3"
                                          Grid.ColumnSpan="2"
                                          IsVisible="{Binding ShowQuickActions}"
                                          BackgroundColor="#55000000"
                                          Padding="10"
                                          ColumnDefinitions="*,Auto,Auto"
                                          VerticalOptions="End">
                                        <Button
                                            Grid.Column="1"
                                            Text="Edit"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCategoryCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#48484A}"
                                            TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"
                                            FontSize="12"
                                            CornerRadius="10"
                                            HeightRequest="32"/>

                                        <Button
                                            Grid.Column="2"
                                            Margin="8,0,0,0"
                                            Text="Delete"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCategoryCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource DestructiveButton}"
                                            FontSize="12"
                                            CornerRadius="10"
                                            HeightRequest="32"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>