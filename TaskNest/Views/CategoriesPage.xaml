<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.CategoriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:TaskNest.Models"
    xmlns:viewModels="clr-namespace:TaskNest.ViewModels"
    x:DataType="viewModels:CategoriesViewModel"
    Title="Categories"
    BackgroundColor="{AppThemeBinding Light=#F6F7FB, Dark=#12151A}">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="18">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Categories"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                <Label
                    Text="Organise your tasks into clear areas of focus."
                    FontSize="15"
                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
            </VerticalStackLayout>

            <!-- New Category Form -->
            <Frame
                Padding="18"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A2230}"
                BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#2B3240}"
                HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="Create Category"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                    <Entry
                        Text="{Binding NewCategoryName, Mode=TwoWay}"
                        Placeholder="Category name"
                        BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#111827}"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                    <Entry
                        Text="{Binding NewCategoryDescription, Mode=TwoWay}"
                        Placeholder="Description (optional)"
                        BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#111827}"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                    <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12">
                        <Button
                            Grid.Column="0"
                            Text="+ Add Category"
                            Command="{Binding AddCategoryCommand}"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="48"/>

                        <Button
                            Grid.Column="1"
                            Text="Refresh"
                            Command="{Binding ManageCategoriesCommand}"
                            BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#1F2937}"
                            TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}"
                            CornerRadius="12"
                            HeightRequest="48"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Compact Stats Bar -->
            <Border
                Padding="14,10"
                Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#2B3240}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1F29}"
                StrokeShape="RoundRectangle 14">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                        ColumnSpacing="10"
                        VerticalOptions="Center">
                    <Label Text="Total"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                    <Label Grid.Column="1"
                           Text="{Binding TotalCategories}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                    <Label Grid.Column="2"
                           Text="•"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"/>

                    <Label Grid.Column="3"
                           Text="Most Active"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                    <Label Grid.Column="4"
                           Text="{Binding MostActiveCategory}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#2563EB"/>

                    <Label Grid.Column="5"
                              Text="Tasks"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>

                          <Label Grid.Column="6"
                              Text="{Binding TasksAssigned}"
                              FontSize="14"
                              FontAttributes="Bold"
                              TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>
                </Grid>
            </Border>

            <!-- Category Hub -->
            <VerticalStackLayout Spacing="14">
                <Label
                    Text="Areas of Focus"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>

                <CollectionView
                    ItemsSource="{Binding Categories}"
                    SelectionMode="None">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Padding="24"
                            Spacing="8">
                            <Label
                                Text="No categories yet"
                                FontSize="18"
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                            <Label
                                Text="Create your first category above to organise tasks."
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                Span="{OnPlatform MacCatalyst=3, Default=2}"
                                HorizontalItemSpacing="14"
                                VerticalItemSpacing="14"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CategoryItem">
                            <Border
                                Padding="14"
                                Stroke="{AppThemeBinding Light=#D5DAE3, Dark=#2B3240}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1F29}"
                                StrokeShape="RoundRectangle 16">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnCategoryCardTapped"/>
                                    <PointerGestureRecognizer
                                        PointerEntered="OnCategoryCardPointerEntered"
                                        PointerExited="OnCategoryCardPointerExited"/>
                                </Border.GestureRecognizers>

                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                            Binding="{Binding IsEmptyState}"
                                            Value="True">
                                        <Setter Property="Stroke"
                                                Value="{AppThemeBinding Light=#CBD5E1, Dark=#3B4254}"/>
                                        <Setter Property="StrokeDashArray"
                                                Value="5,4"/>
                                        <Setter Property="Opacity"
                                                Value="0.92"/>
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid RowDefinitions="Auto,Auto,Auto"
                                        ColumnDefinitions="8,*">
                                    <BoxView
                                        Grid.RowSpan="3"
                                        Grid.Column="0"
                                        CornerRadius="4"
                                        Color="{Binding AccentColor}"/>

                                    <Grid Grid.Column="1"
                                            ColumnDefinitions="Auto,*"
                                            ColumnSpacing="8"
                                            Padding="10,0,0,0">
                                        <Label
                                            Text="{Binding IconGlyph}"
                                            FontSize="17"
                                            VerticalOptions="Center"
                                            TextColor="{Binding AccentColor}"/>

                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label
                                                Text="{Binding Name}"
                                                FontSize="17"
                                                FontAttributes="Bold"
                                                TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"/>
                                            <Label
                                                Text="{Binding Description}"
                                                FontSize="13"
                                                MaxLines="1"
                                                LineBreakMode="TailTruncation"
                                                TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                                        </VerticalStackLayout>
                                    </Grid>

                                    <VerticalStackLayout Grid.Row="1"
                                            Grid.Column="1"
                                            Spacing="6"
                                            Padding="10,12,0,0">
                                        <ProgressBar
                                            Progress="{Binding ProgressValue}"
                                            ProgressColor="{Binding AccentColor}"
                                            BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                                            HeightRequest="6"/>
                                        <Label
                                            Text="{Binding ProgressText}"
                                            FontSize="12"
                                            FontAttributes="Italic"
                                            TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                                    </VerticalStackLayout>

                                    <Grid Grid.RowSpan="3"
                                            Grid.ColumnSpan="2"
                                            IsVisible="{Binding ShowQuickActions}"
                                            BackgroundColor="#55000000"
                                            Padding="10"
                                            ColumnDefinitions="*,Auto,Auto"
                                            VerticalOptions="End">
                                        <Button
                                            Grid.Column="1"
                                            Text="Edit"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCategoryCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#374151}"
                                            TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}"
                                            FontSize="12"
                                            CornerRadius="10"
                                            HeightRequest="34"/>

                                        <Button
                                            Grid.Column="2"
                                            Margin="8,0,0,0"
                                            Text="Delete"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCategoryCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#FEE2E2"
                                            TextColor="#B91C1C"
                                            FontSize="12"
                                            CornerRadius="10"
                                            HeightRequest="34"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>