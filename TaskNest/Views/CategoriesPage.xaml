<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskNest.Views.CategoriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Categories"
    BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="22">

            <!-- Header -->
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Categories"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="#111827"/>

                <Label
                    Text="Organise your tasks into clear areas of focus."
                    FontSize="15"
                    TextColor="#6B7280"/>
            </VerticalStackLayout>

            <!-- Action Row -->
            <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    Text="+ Add Category"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="48"/>

                <Button
                    Grid.Column="1"
                    Text="Manage Categories"
                    BackgroundColor="#E5E7EB"
                    TextColor="#111827"
                    CornerRadius="12"
                    HeightRequest="48"/>
            </Grid>

            <!-- Summary Card -->
            <Frame
                Padding="20"
                CornerRadius="18"
                BackgroundColor="White"
                HasShadow="True">
                <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Total Categories"
                            FontSize="14"
                            TextColor="#6B7280"/>
                        <Label
                            Text="4"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="#111827"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1"
                            Spacing="4">
                        <Label
                            Text="Most Active"
                            FontSize="14"
                            TextColor="#6B7280"/>
                        <Label
                            Text="University"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#2563EB"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2"
                            Spacing="4">
                        <Label
                            Text="Tasks Assigned"
                            FontSize="14"
                            TextColor="#6B7280"/>
                        <Label
                            Text="12"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="#10B981"/>
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- Category List -->
            <VerticalStackLayout Spacing="14">
                <Label
                    Text="Your Categories"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="#111827"/>

                <!-- Category Card 1 -->
                <Frame
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="White"
                    HasShadow="True">
                    <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="University"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Label
                                Text="Assignments, coursework, and revision tasks."
                                FontSize="14"
                                TextColor="#6B7280"/>
                        </VerticalStackLayout>

                        <Frame
                            Padding="10,6"
                            CornerRadius="14"
                            HasShadow="False"
                            BackgroundColor="#DBEAFE"
                            VerticalOptions="Start">
                            <Label
                                Text="4 Tasks"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="#1D4ED8"/>
                        </Frame>
                    </Grid>
                </Frame>

                <!-- Category Card 2 -->
                <Frame
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="White"
                    HasShadow="True">
                    <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Work"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Label
                                Text="Shifts, responsibilities, and job-related tasks."
                                FontSize="14"
                                TextColor="#6B7280"/>
                        </VerticalStackLayout>

                        <Frame
                            Padding="10,6"
                            CornerRadius="14"
                            HasShadow="False"
                            BackgroundColor="#DCFCE7"
                            VerticalOptions="Start">
                            <Label
                                Text="2 Tasks"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="#15803D"/>
                        </Frame>
                    </Grid>
                </Frame>

                <!-- Category Card 3 -->
                <Frame
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="White"
                    HasShadow="True">
                    <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Personal"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Label
                                Text="Gym, lifestyle, errands, and self-development goals."
                                FontSize="14"
                                TextColor="#6B7280"/>
                        </VerticalStackLayout>

                        <Frame
                            Padding="10,6"
                            CornerRadius="14"
                            HasShadow="False"
                            BackgroundColor="#FEF3C7"
                            VerticalOptions="Start">
                            <Label
                                Text="6 Tasks"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="#B45309"/>
                        </Frame>
                    </Grid>
                </Frame>

                <!-- Category Card 4 -->
                <Frame
                    Padding="18"
                    CornerRadius="18"
                    BackgroundColor="White"
                    HasShadow="True">
                    <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Health"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#111827"/>
                            <Label
                                Text="Meal prep, recovery, running, and physical wellbeing."
                                FontSize="14"
                                TextColor="#6B7280"/>
                        </VerticalStackLayout>

                        <Frame
                            Padding="10,6"
                            CornerRadius="14"
                            HasShadow="False"
                            BackgroundColor="#FCE7F3"
                            VerticalOptions="Start">
                            <Label
                                Text="3 Tasks"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="#BE185D"/>
                        </Frame>
                    </Grid>
                </Frame>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>