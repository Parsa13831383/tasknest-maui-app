<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TaskNest.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TaskNest.Views"
    FlyoutBehavior="Flyout"
    Title="TaskNest">

    <FlyoutItem Title="Dashboard"
            Route="dashboard">
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Tasks"
            Route="tasks">
        <ShellContent
            Title="Tasks"
            ContentTemplate="{DataTemplate views:TasksPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Categories"
            Route="categories">
        <ShellContent
            Title="Categories"
            ContentTemplate="{DataTemplate views:CategoriesPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Settings"
            Route="settings">
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate views:SettingsPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Profile"
            Route="profile">
        <ShellContent
            Title="Profile"
            ContentTemplate="{DataTemplate views:ProfilePage}"/>
    </FlyoutItem>

</Shell>